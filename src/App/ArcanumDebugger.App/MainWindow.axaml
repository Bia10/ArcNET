<Window
  x:Class="ArcanumDebugger.App.MainWindow"
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:composition="using:ArcanumDebugger.App.Composition"
  xmlns:controls="using:ArcanumDebugger.App.Controls"
  xmlns:contracts="using:ArcNET.Diagnostics.Contracts"
  xmlns:workspace="using:ArcNET.GameData.Workspace"
  xmlns:core="using:ArcNET.Diagnostics"
  xmlns:diag="using:ArcNET.Diagnostics"
  xmlns:viewmodels="using:ArcanumDebugger.App.ViewModels"
  x:Name="RootWindow"
  x:DataType="viewmodels:MainWindowViewModel"
  Width="1480"
  Height="960"
  MinWidth="1260"
  MinHeight="780"
  Background="Transparent"
  Title="ArcanumDebugger Preview"
>
  <Window.Resources>
    <SolidColorBrush x:Key="ShellBackgroundBrush" Color="#0D1117" />
    <SolidColorBrush x:Key="SidebarBrush" Color="#11161D" />
    <SolidColorBrush x:Key="PanelBrush" Color="#161B22" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#30363D" />
    <SolidColorBrush x:Key="InkBrush" Color="#E6EDF3" />
    <SolidColorBrush x:Key="MutedInkBrush" Color="#8B949E" />
    <SolidColorBrush x:Key="SoftLineBrush" Color="#30363D" />
  </Window.Resources>

  <Window.Styles>
    <Style Selector="Window">
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
      <Setter Property="Background" Value="{DynamicResource ShellBackgroundBrush}" />
    </Style>
    <Style Selector="Border.panel">
      <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="10" />
    </Style>
    <Style Selector="Border.metric">
      <Setter Property="Background" Value="#11161D" />
      <Setter Property="BorderBrush" Value="{DynamicResource SoftLineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="8" />
    </Style>
    <Style Selector="TextBlock.h1">
      <Setter Property="FontSize" Value="18" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.h2">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.h3">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.meta">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="{DynamicResource MutedInkBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.code">
      <Setter Property="FontFamily" Value="Cascadia Code, Consolas" />
      <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="Button">
      <Setter Property="Background" Value="#21262D" />
      <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Duration="0:0:0.15" Property="Background" />
          <BrushTransition Duration="0:0:0.15" Property="BorderBrush" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#30363D" />
      <Setter Property="BorderBrush" Value="#58A6FF" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#1F6FEB" />
      <Setter Property="BorderBrush" Value="#58A6FF" />
    </Style>
    <Style Selector="Button:disabled /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#161B22" />
      <Setter Property="BorderBrush" Value="#21262D" />
      <Setter Property="Foreground" Value="#6E7681" />
    </Style>
    <Style Selector="Button.action">
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Background" Value="#1F6FEB" />
      <Setter Property="BorderBrush" Value="#1F6FEB" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.secondary">
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Background" Value="#21262D" />
      <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
    </Style>
    <Style Selector="TextBox">
      <Setter Property="Background" Value="#0D1117" />
      <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Padding" Value="8,4" />
    </Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="#0D1117" />
      <Setter Property="BorderBrush" Value="#58A6FF" />
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="Background" Value="#0D1117" />
      <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Padding" Value="10,5" />
    </Style>
    <Style Selector="ComboBox:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#21262D" />
      <Setter Property="BorderBrush" Value="#58A6FF" />
    </Style>
    <Style Selector="CheckBox">
      <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
    </Style>
    <Style Selector="TabItem">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="8,4" />
    </Style>
    <Style Selector="ListBox.sidebar">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
  </Window.Styles>

  <Grid>
    <Border Background="{DynamicResource ShellBackgroundBrush}" />

    <Grid Margin="12" RowDefinitions="Auto,*" ColumnDefinitions="220,*" ColumnSpacing="12" RowSpacing="12">
      <Border Grid.ColumnSpan="2" Classes="panel" Padding="8,6">
        <Grid ColumnDefinitions="1.35*,0.8*,0.8*,0.7*" ColumnSpacing="8">
          <StackPanel Spacing="4">
            <TextBlock Classes="h2" Text="{CompiledBinding RuntimeTitle}" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Border Background="{CompiledBinding SupportAccentBrush}" CornerRadius="999" Padding="8,3">
                <TextBlock
                  Classes="meta"
                  FontWeight="SemiBold"
                  Foreground="White"
                  Text="{CompiledBinding SupportBadgeText}"
                />
              </Border>
              <Border Background="#21262D" CornerRadius="999" Padding="8,3">
                <TextBlock Classes="meta" Text="{CompiledBinding RuntimeKindText}" />
              </Border>
              <Border Background="#21262D" CornerRadius="999" Padding="8,3">
                <TextBlock Classes="meta" Text="{CompiledBinding SymbolStateText}" />
              </Border>
            </StackPanel>
          </StackPanel>

          <Border Classes="metric" Grid.Column="1">
            <StackPanel Spacing="2">
              <TextBlock Classes="meta" Text="Workspace" />
              <TextBlock Classes="h3" Text="{CompiledBinding WorkspaceSourceText}" />
              <TextBlock Classes="meta" Text="{CompiledBinding GeneratedAgoText}" />
            </StackPanel>
          </Border>

          <Border Classes="metric" Grid.Column="2">
            <StackPanel Spacing="2">
              <TextBlock Classes="meta" Text="Session" />
              <TextBlock Classes="h3" Text="{CompiledBinding SessionSupportBadgeText}" />
              <TextBlock Classes="meta" Text="{CompiledBinding SessionHeadlineText}" />
            </StackPanel>
          </Border>

          <Border Classes="metric" Grid.Column="3">
            <StackPanel Spacing="2">
              <TextBlock Classes="meta" Text="Watch" />
              <TextBlock Classes="h3" Text="{CompiledBinding TimelineHeadlineText}" />
              <TextBlock Classes="meta" Text="{CompiledBinding LiveTimelineStatusText}" />
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <Border Grid.Row="1" Classes="panel" Background="{DynamicResource SidebarBrush}" Padding="10">
        <Grid RowDefinitions="Auto,*" RowSpacing="8">
          <StackPanel Spacing="8">
            <TextBlock Classes="h1" Text="ArcanumDebugger" />
            <Button Classes="action" Command="{CompiledBinding RefreshWorkspaceCommand}" Content="Refresh" />
          </StackPanel>

          <StackPanel Grid.Row="1" Spacing="8">
            <TextBlock Classes="h2" Text="Runtime profiles" />
            <ListBox
              Classes="sidebar"
              ItemsSource="{CompiledBinding Scenarios}"
              SelectedItem="{CompiledBinding SelectedScenario, Mode=TwoWay}"
            >
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="composition:ArcanumDebuggerPreviewScenario">
                  <Border
                    Margin="0,0,0,6"
                    Background="#151A20"
                    BorderBrush="{DynamicResource SoftLineBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="8"
                  >
                    <StackPanel Spacing="2">
                      <TextBlock Classes="h3" Text="{CompiledBinding DisplayName}" />
                      <TextBlock Classes="meta" Text="{CompiledBinding WorkspaceRequest.RuntimeProfile.DisplayName}" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </StackPanel>
        </Grid>
      </Border>

      <Border Grid.Row="1" Grid.Column="1" Classes="panel" Padding="0">
        <TabControl
          Margin="12"
          SelectedIndex="{CompiledBinding SelectedRootTabIndex, Mode=TwoWay}"
          TabStripPlacement="Top"
        >
          <TabItem Header="Connect">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <Grid Margin="2,12,2,2" RowDefinitions="Auto,Auto,Auto" RowSpacing="16">
                <Grid ColumnDefinitions="1.1*,0.9*" ColumnSpacing="16">
                  <Border Classes="metric">
                    <StackPanel Spacing="8">
                      <TextBlock Classes="h2" Text="Live Sessions" />
                      <Button
                        Classes="action"
                        Command="{CompiledBinding AttachSelectedRuntimeCommand}"
                        Content="Attach"
                        IsEnabled="{CompiledBinding CanAttachSelectedRuntime}"
                      />
                      <TextBlock Classes="h3" Text="Processes" />
                      <ItemsControl ItemsSource="{CompiledBinding ProcessCandidates}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="core:ProcessCandidateSnapshot">
                            <Border
                              Margin="0,0,0,6"
                              Background="#151A20"
                              BorderBrush="{DynamicResource SoftLineBrush}"
                              BorderThickness="1"
                              CornerRadius="6"
                              Padding="8,6"
                            >
                              <DockPanel>
                                <StackPanel DockPanel.Dock="Left" Spacing="2">
                                  <TextBlock Classes="h3" Text="{CompiledBinding DisplayName}" />
                                  <TextBlock Classes="meta" Text="{CompiledBinding StatusText}" />
                                </StackPanel>
                                <Border DockPanel.Dock="Right" Background="#21262D" CornerRadius="999" Padding="8,3">
                                  <TextBlock Classes="meta" Text="{CompiledBinding RunningInstanceCount}" />
                                </Border>
                              </DockPanel>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>

                      <TextBlock Classes="h3" Text="Sessions" />
                      <ListBox
                        Classes="sidebar"
                        ItemsSource="{CompiledBinding LiveRuntimes}"
                        MaxHeight="260"
                        SelectedItem="{CompiledBinding SelectedLiveRuntime, Mode=TwoWay}"
                      >
                        <ListBox.ItemTemplate>
                          <DataTemplate x:DataType="core:LiveRuntimeSnapshot">
                            <Border
                              Margin="0,0,0,6"
                              Background="#151A20"
                              BorderBrush="{DynamicResource SoftLineBrush}"
                              BorderThickness="1"
                              CornerRadius="6"
                              Padding="8,6"
                            >
                              <StackPanel Spacing="3">
                                <TextBlock Classes="h3" Text="{CompiledBinding DisplayName}" />
                                <TextBlock
                                  Classes="code"
                                  Text="{CompiledBinding Fingerprint.ModulePath}"
                                  TextWrapping="Wrap"
                                />
                              </StackPanel>
                            </Border>
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>
                    </StackPanel>
                  </Border>

                  <Border Classes="metric" Grid.Column="1">
                    <StackPanel Spacing="8">
                      <TextBlock Classes="h2" Text="Launch" />
                      <TextBox PlaceholderText="C:\Games\Arcanum" Text="{CompiledBinding InstallPath, Mode=TwoWay}" />
                      <ComboBox
                        ItemsSource="{CompiledBinding LaunchExecutableOptions}"
                        SelectedItem="{CompiledBinding SelectedLaunchExecutableOption, Mode=TwoWay}"
                      >
                        <ComboBox.ItemTemplate>
                          <DataTemplate x:DataType="viewmodels:LaunchExecutableKindOption">
                            <TextBlock Text="{CompiledBinding Label}" />
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                      <CheckBox Content="CE windowed" IsChecked="{CompiledBinding LaunchWindowed, Mode=TwoWay}" />
                      <Button
                        Classes="action"
                        Command="{CompiledBinding LaunchAndAttachCommand}"
                        Content="Launch &amp; Attach"
                      />
                      <Border
                        Background="#151A20"
                        BorderBrush="{DynamicResource SoftLineBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8,6"
                      >
                        <StackPanel Spacing="4">
                          <TextBlock Classes="h3" Text="{CompiledBinding LaunchPreviewSummaryText}" />
                        </StackPanel>
                      </Border>
                    </StackPanel>
                  </Border>
                </Grid>

                <Border Classes="metric" Grid.Row="1">
                  <StackPanel Spacing="8">
                    <DockPanel>
                      <StackPanel DockPanel.Dock="Left" Spacing="2">
                        <TextBlock Classes="h2" Text="Current Session" />
                      </StackPanel>
                      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
                        <Button
                          Classes="secondary"
                          Command="{CompiledBinding RefreshActiveSessionCommand}"
                          Content="Refresh"
                        />
                        <Button
                          Classes="secondary"
                          Command="{CompiledBinding DisconnectSessionCommand}"
                          Content="Disconnect"
                        />
                      </StackPanel>
                    </DockPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Border Background="#21262D" CornerRadius="999" Padding="8,3">
                        <TextBlock Classes="meta" Text="{CompiledBinding SessionOriginText}" />
                      </Border>
                      <Border Background="{CompiledBinding SessionSupportAccentBrush}" CornerRadius="999" Padding="8,3">
                        <TextBlock
                          Classes="meta"
                          FontWeight="SemiBold"
                          Foreground="White"
                          Text="{CompiledBinding SessionSupportBadgeText}"
                        />
                      </Border>
                    </StackPanel>

                    <TextBlock Classes="h1" Text="{CompiledBinding SessionHeadlineText}" />
                    <TextBlock Classes="code" Text="{CompiledBinding SessionDetailText}" TextWrapping="Wrap" />

                    <Border
                      Background="#151A20"
                      BorderBrush="{DynamicResource SoftLineBrush}"
                      BorderThickness="1"
                      CornerRadius="6"
                      Padding="8,6"
                    >
                      <StackPanel Spacing="6">
                        <DockPanel>
                          <TextBlock DockPanel.Dock="Left" Classes="h3" Text="Local Workspace Override" />
                          <Button
                            DockPanel.Dock="Right"
                            Classes="secondary"
                            Command="{CompiledBinding ClearWorkspaceOverridePathCommand}"
                            Content="Clear"
                          />
                        </DockPanel>
                        <TextBox
                          PlaceholderText="Optional module or workspace path"
                          Text="{CompiledBinding WorkspaceOverridePathText, Mode=TwoWay}"
                        />
                        <TextBlock
                          Classes="meta"
                          Text="When set, local catalog, prototype, guided-world, and journal tools use this path instead of the attached executable path."
                          TextWrapping="Wrap"
                        />
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </Border>

                <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="16">
                  <Border Classes="metric">
                    <StackPanel Spacing="8">
                      <TextBlock Classes="h2" Text="Panels" />
                      <ItemsControl ItemsSource="{CompiledBinding FeaturedPanels}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="diag:WorkspacePanelWorkflowSnapshot">
                            <Border
                              Margin="0,0,0,6"
                              Background="#151A20"
                              BorderBrush="{DynamicResource SoftLineBrush}"
                              BorderThickness="1"
                              CornerRadius="6"
                              Padding="8,6"
                            >
                              <StackPanel Spacing="3">
                                <DockPanel>
                                  <TextBlock
                                    DockPanel.Dock="Left"
                                    Classes="h3"
                                    Text="{CompiledBinding PanelDisplayName}"
                                  />
                                  <Border DockPanel.Dock="Right" Background="#21262D" CornerRadius="999" Padding="8,3">
                                    <TextBlock Classes="meta" Text="{CompiledBinding ShellSurfaceText}" />
                                  </Border>
                                </DockPanel>
                                <TextBlock Classes="code" Text="{CompiledBinding WorkflowTitle}" TextWrapping="Wrap" />
                              </StackPanel>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </Border>

                  <Border Classes="metric" Grid.Column="1">
                    <StackPanel Spacing="8">
                      <TextBlock Classes="h2" Text="Profiles" />
                      <ItemsControl ItemsSource="{CompiledBinding FeaturedProbeProfiles}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="contracts:ProbeProfile">
                            <Border
                              Margin="0,0,0,6"
                              Background="#151A20"
                              BorderBrush="{DynamicResource SoftLineBrush}"
                              BorderThickness="1"
                              CornerRadius="6"
                              Padding="8,6"
                            >
                              <StackPanel Spacing="3">
                                <TextBlock Classes="h3" Text="{CompiledBinding DisplayName}" />
                                <TextBlock Classes="code" Text="{CompiledBinding Key}" />
                              </StackPanel>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </Border>
                </Grid>
              </Grid>
            </ScrollViewer>
          </TabItem>

          <TabItem Header="Read">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="2,12,2,2" Spacing="16">
                <TabControl SelectedIndex="{CompiledBinding SelectedReadTabIndex, Mode=TwoWay}">
                  <TabItem Header="Player">
                    <StackPanel Margin="0,12,0,0" Spacing="16">
                      <TabControl>
                        <TabItem Header="Character Sheet">
                          <Grid Margin="0,0,0,0" ColumnDefinitions="0.95*,1.05*" ColumnSpacing="16">
                            <Border Classes="metric">
                              <StackPanel Spacing="8">
                                <TextBlock Classes="h2" Text="Character Sheet" />
                                <Grid ColumnDefinitions="1*,Auto" ColumnSpacing="8">
                                  <TextBox
                                    PlaceholderText="Handle token (player)"
                                    Text="{CompiledBinding SheetHandleTokenText, Mode=TwoWay}"
                                  />
                                  <Button
                                    Grid.Column="1"
                                    Classes="secondary"
                                    Command="{CompiledBinding UseSelectedMobileForSheetTargetCommand}"
                                    Content="Use Roster"
                                    IsEnabled="{CompiledBinding CanUseSelectedMobileRosterHandle}"
                                  />
                                </Grid>
                                <Grid ColumnDefinitions="1.1*,0.7*" ColumnSpacing="8">
                                  <TextBox
                                    PlaceholderText="Field (level, strength, haggle)"
                                    Text="{CompiledBinding SheetLabelText, Mode=TwoWay}"
                                  />
                                  <TextBox
                                    Grid.Column="1"
                                    PlaceholderText="Diff delay ms"
                                    Text="{CompiledBinding SheetDiffDelayText, Mode=TwoWay}"
                                  />
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                  <Button
                                    Classes="secondary"
                                    Command="{CompiledBinding ReadSheetDiagnosticsCommand}"
                                    Content="Read"
                                  />
                                  <Button
                                    Classes="secondary"
                                    Command="{CompiledBinding ScanSheetDiagnosticsCommand}"
                                    Content="Scan"
                                  />
                                  <Button
                                    Classes="secondary"
                                    Command="{CompiledBinding DiffSheetDiagnosticsCommand}"
                                    Content="Diff"
                                  />
                                </StackPanel>
                                <TextBlock
                                  Classes="meta"
                                  Text="Scan also refreshes the editable-field browser on the right. Use Roster copies the selected mobile so companions can be targeted without retyping one live handle."
                                  TextWrapping="Wrap"
                                />
                              </StackPanel>
                            </Border>

                            <StackPanel Grid.Column="1" Spacing="16">
                              <Border Classes="metric">
                                <StackPanel Spacing="8">
                                  <TextBlock Classes="h2" Text="Results" />
                                  <TextBlock Classes="h3" Text="{CompiledBinding SheetStatusText}" />
                                  <ItemsControl ItemsSource="{CompiledBinding SheetResultLines}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate>
                                        <TextBlock Classes="meta" Text="{Binding}" TextWrapping="Wrap" />
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </StackPanel>
                              </Border>
                              <Border Classes="metric">
                                <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="8">
                                  <DockPanel LastChildFill="False">
                                    <TextBlock Classes="h2" DockPanel.Dock="Left" Text="Editable Fields" />
                                    <Button
                                      Classes="action"
                                      Command="{CompiledBinding LoadSheetEditableFieldsCommand}"
                                      Content="Load Fields"
                                      DockPanel.Dock="Right"
                                      IsEnabled="{CompiledBinding CanLoadSheetEditableFields}"
                                    />
                                  </DockPanel>
                                  <TextBlock
                                    Grid.Row="1"
                                    Classes="meta"
                                    Text="{CompiledBinding SheetEditableFieldSummaryText}"
                                    TextWrapping="Wrap"
                                  />
                                  <TextBox
                                    Grid.Row="2"
                                    PlaceholderText="Filter by name, category, token, or current value"
                                    Text="{CompiledBinding SheetEditableFieldFilterText, Mode=TwoWay}"
                                  />
                                  <ListBox
                                    Grid.Row="3"
                                    Classes="sidebar"
                                    ItemsSource="{CompiledBinding SheetEditableFields}"
                                    MaxHeight="340"
                                    MinHeight="220"
                                    SelectedItem="{CompiledBinding SelectedSheetEditableField, Mode=TwoWay}"
                                  >
                                    <ListBox.ItemTemplate>
                                      <DataTemplate x:DataType="viewmodels:DebuggerSheetEditableField">
                                        <Border
                                          Margin="0,0,0,6"
                                          Background="#151A20"
                                          BorderBrush="{DynamicResource SoftLineBrush}"
                                          BorderThickness="1"
                                          CornerRadius="6"
                                          Padding="8,6"
                                        >
                                          <StackPanel Spacing="3">
                                            <DockPanel LastChildFill="False">
                                              <TextBlock
                                                Classes="h3"
                                                DockPanel.Dock="Left"
                                                Text="{CompiledBinding DisplayName}"
                                              />
                                              <Border
                                                Background="#21262D"
                                                CornerRadius="999"
                                                DockPanel.Dock="Right"
                                                Padding="8,3"
                                              >
                                                <TextBlock Classes="meta" Text="{CompiledBinding Category}" />
                                              </Border>
                                            </DockPanel>
                                            <TextBlock Classes="code" Text="{CompiledBinding CurrentValueText}" />
                                            <TextBlock
                                              Classes="meta"
                                              Text="{CompiledBinding DetailText}"
                                              TextWrapping="Wrap"
                                            />
                                          </StackPanel>
                                        </Border>
                                      </DataTemplate>
                                    </ListBox.ItemTemplate>
                                  </ListBox>
                                </Grid>
                              </Border>

                              <Border Classes="metric">
                                <StackPanel Spacing="8">
                                  <TextBlock Classes="h2" Text="Edit Field" />
                                  <TextBlock Classes="meta" Text="{CompiledBinding SheetMutationStatusText}" />
                                  <TextBox
                                    PlaceholderText="Field token or selected field"
                                    Text="{CompiledBinding SheetLabelText, Mode=TwoWay}"
                                  />
                                  <Grid ColumnDefinitions="1*,1*" ColumnSpacing="8">
                                    <ComboBox
                                      IsVisible="{CompiledBinding SheetMutationShowValueSelector}"
                                      ItemsSource="{CompiledBinding SheetMutationValueOptions}"
                                      SelectedItem="{CompiledBinding SelectedSheetMutationValueOption, Mode=TwoWay}"
                                    >
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="viewmodels:DebuggerChoiceOption">
                                          <TextBlock Text="{CompiledBinding Label}" />
                                        </DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <TextBox
                                      IsVisible="{CompiledBinding SheetMutationShowValueInput}"
                                      PlaceholderText="{CompiledBinding SheetMutationValuePlaceholderText}"
                                      Text="{CompiledBinding SheetMutationValueText, Mode=TwoWay}"
                                    />
                                    <ComboBox
                                      Grid.Column="1"
                                      IsVisible="{CompiledBinding SheetMutationShowTrainingSelector}"
                                      ItemsSource="{CompiledBinding SheetMutationTrainingOptions}"
                                      SelectedItem="{CompiledBinding SelectedSheetMutationTrainingOption, Mode=TwoWay}"
                                    >
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="viewmodels:DebuggerChoiceOption">
                                          <TextBlock Text="{CompiledBinding Label}" />
                                        </DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <TextBox
                                      Grid.Column="1"
                                      IsVisible="{CompiledBinding SheetMutationShowTrainingInput}"
                                      PlaceholderText="{CompiledBinding SheetMutationTrainingPlaceholderText}"
                                      Text="{CompiledBinding SheetMutationTrainingText, Mode=TwoWay}"
                                    />
                                  </Grid>
                                  <Grid ColumnDefinitions="0.8*,Auto" ColumnSpacing="8">
                                    <TextBox
                                      PlaceholderText="Timeout ms"
                                      Text="{CompiledBinding SheetMutationTimeoutText, Mode=TwoWay}"
                                    />
                                    <Button
                                      Grid.Column="1"
                                      Classes="action"
                                      Command="{CompiledBinding ApplySheetMutationCommand}"
                                      Content="Apply"
                                      IsEnabled="{CompiledBinding CanApplySheetMutation}"
                                    />
                                  </Grid>
                                  <TextBlock
                                    Classes="meta"
                                    Text="{CompiledBinding SheetMutationInputHintText}"
                                    TextWrapping="Wrap"
                                  />
                                  <Border
                                    Background="#151A20"
                                    BorderBrush="{DynamicResource SoftLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    IsVisible="{CompiledBinding SheetMutationShowLiveStateInspector}"
                                    Padding="8,6"
                                  >
                                    <StackPanel Spacing="6">
                                      <TextBlock
                                        Classes="h3"
                                        Text="{CompiledBinding SheetMutationLiveStateStatusText}"
                                      />
                                      <TextBlock
                                        Classes="meta"
                                        Text="{CompiledBinding SheetMutationLiveStateSummaryText}"
                                        TextWrapping="Wrap"
                                      />
                                      <Grid ColumnDefinitions="1*,1*,Auto" ColumnSpacing="8">
                                        <TextBox
                                          IsReadOnly="True"
                                          PlaceholderText="Current value"
                                          Text="{CompiledBinding SheetMutationLiveStateValueText}"
                                        />
                                        <TextBox
                                          Grid.Column="1"
                                          IsReadOnly="True"
                                          IsVisible="{CompiledBinding SheetMutationLiveStateShowTrainingText}"
                                          PlaceholderText="Current training"
                                          Text="{CompiledBinding SheetMutationLiveStateTrainingText}"
                                        />
                                        <Button
                                          Grid.Column="2"
                                          Classes="secondary"
                                          Command="{CompiledBinding UseSheetLiveStateValueCommand}"
                                          Content="Use Current"
                                          IsEnabled="{CompiledBinding CanUseSheetLiveStateValue}"
                                        />
                                      </Grid>
                                    </StackPanel>
                                  </Border>
                                  <ItemsControl ItemsSource="{CompiledBinding SheetMutationResultLines}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate>
                                        <TextBlock Classes="meta" Text="{Binding}" TextWrapping="Wrap" />
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                  <Border
                                    Background="#151A20"
                                    BorderBrush="{DynamicResource SoftLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8,6"
                                  >
                                    <StackPanel Spacing="4">
                                      <TextBlock Classes="h3" Text="Result" />
                                      <TextBlock
                                        Classes="meta"
                                        Text="{CompiledBinding SheetMutationDispatcherText}"
                                        TextWrapping="Wrap"
                                      />
                                      <TextBlock
                                        Classes="meta"
                                        Text="{CompiledBinding SheetMutationExecutionDetailText}"
                                        TextWrapping="Wrap"
                                      />
                                      <TextBlock Classes="code" Text="{CompiledBinding SheetMutationResultText}" />
                                    </StackPanel>
                                  </Border>
                                </StackPanel>
                              </Border>
                            </StackPanel>
                          </Grid>
                        </TabItem>

                        <TabItem Header="Journal">
                          <Grid Margin="0,0,0,0" ColumnDefinitions="0.92*,1.08*" ColumnSpacing="16">
                            <Border Classes="metric">
                              <StackPanel Spacing="8">
                                <TextBlock Classes="h2" Text="Journal" />
                                <Grid ColumnDefinitions="1*,Auto" ColumnSpacing="8">
                                  <TextBox
                                    PlaceholderText="Handle token (player)"
                                    Text="{CompiledBinding LogbookHandleTokenText, Mode=TwoWay}"
                                  />
                                  <Button
                                    Grid.Column="1"
                                    Classes="secondary"
                                    Command="{CompiledBinding UseSelectedMobileForLogbookTargetCommand}"
                                    Content="Use Roster"
                                    IsEnabled="{CompiledBinding CanUseSelectedMobileRosterHandle}"
                                  />
                                </Grid>
                                <ComboBox
                                  ItemsSource="{CompiledBinding LogbookPageOptions}"
                                  SelectedItem="{CompiledBinding SelectedLogbookPageOption, Mode=TwoWay}"
                                >
                                  <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:DebuggerChoiceOption">
                                      <TextBlock Text="{CompiledBinding Label}" />
                                    </DataTemplate>
                                  </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Button
                                  Classes="secondary"
                                  Command="{CompiledBinding ReadLogbookDiagnosticsCommand}"
                                  Content="Load Page"
                                />
                                <TextBlock
                                  Classes="meta"
                                  Text="Use Roster copies the selected mobile from the Mobiles tab so you can inspect companion journal data without retyping live handles."
                                  TextWrapping="Wrap"
                                />
                                <TextBlock Classes="h3" Text="{CompiledBinding LogbookStatusText}" />

                                <ItemsControl ItemsSource="{CompiledBinding LogbookHighlights}">
                                  <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                      <WrapPanel />
                                    </ItemsPanelTemplate>
                                  </ItemsControl.ItemsPanel>
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:DebuggerLogbookSummaryCard">
                                      <Border
                                        Width="170"
                                        Margin="0,0,10,10"
                                        Background="#151A20"
                                        BorderBrush="{DynamicResource SoftLineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8,6"
                                      >
                                        <StackPanel Spacing="2">
                                          <TextBlock Classes="meta" Text="{CompiledBinding Label}" />
                                          <TextBlock Classes="h3" Text="{CompiledBinding Value}" />
                                          <TextBlock
                                            Classes="meta"
                                            Text="{CompiledBinding Detail}"
                                            TextWrapping="Wrap"
                                          />
                                        </StackPanel>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </StackPanel>
                            </Border>

                            <StackPanel Grid.Column="1" Spacing="16">
                              <Border Classes="metric" IsVisible="{CompiledBinding HasLogbookSections}">
                                <StackPanel Spacing="8">
                                  <TextBlock Classes="h2" Text="Sections" />
                                  <ItemsControl ItemsSource="{CompiledBinding LogbookSections}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate x:DataType="viewmodels:DebuggerLogbookSection">
                                        <Border
                                          Margin="0,0,0,10"
                                          Background="#151A20"
                                          BorderBrush="{DynamicResource SoftLineBrush}"
                                          BorderThickness="1"
                                          CornerRadius="6"
                                          Padding="8,6"
                                        >
                                          <StackPanel Spacing="6">
                                            <TextBlock Classes="h3" Text="{CompiledBinding Title}" />
                                            <TextBlock
                                              Classes="meta"
                                              Text="{CompiledBinding Summary}"
                                              TextWrapping="Wrap"
                                            />
                                            <ItemsControl ItemsSource="{CompiledBinding Entries}">
                                              <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                  <TextBlock
                                                    Classes="meta"
                                                    Margin="0,0,0,4"
                                                    Text="{Binding}"
                                                    TextWrapping="Wrap"
                                                  />
                                                </DataTemplate>
                                              </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                          </StackPanel>
                                        </Border>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </StackPanel>
                              </Border>

                              <Border Classes="metric">
                                <StackPanel Spacing="8">
                                  <TextBlock Classes="h2" Text="Live Entry Shortcuts" />
                                  <TextBlock
                                    Classes="meta"
                                    Text="{CompiledBinding LogbookEditableEntrySummaryText}"
                                    TextWrapping="Wrap"
                                  />
                                  <ListBox
                                    Classes="sidebar"
                                    ItemsSource="{CompiledBinding LogbookEditableEntries}"
                                    MaxHeight="280"
                                    MinHeight="150"
                                    SelectedItem="{CompiledBinding SelectedLogbookEditableEntry, Mode=TwoWay}"
                                  >
                                    <ListBox.ItemTemplate>
                                      <DataTemplate x:DataType="viewmodels:DebuggerLogbookEditableEntry">
                                        <Border
                                          Margin="0,0,0,6"
                                          Background="#151A20"
                                          BorderBrush="{DynamicResource SoftLineBrush}"
                                          BorderThickness="1"
                                          CornerRadius="6"
                                          Padding="8,6"
                                        >
                                          <StackPanel Spacing="3">
                                            <DockPanel LastChildFill="False">
                                              <TextBlock
                                                Classes="h3"
                                                DockPanel.Dock="Left"
                                                Text="{CompiledBinding DisplayName}"
                                              />
                                              <Border
                                                Background="#21262D"
                                                CornerRadius="999"
                                                DockPanel.Dock="Right"
                                                Padding="8,3"
                                              >
                                                <TextBlock Classes="meta" Text="{CompiledBinding Category}" />
                                              </Border>
                                            </DockPanel>
                                            <TextBlock Classes="code" Text="{CompiledBinding CurrentValueText}" />
                                            <TextBlock
                                              Classes="meta"
                                              Text="{CompiledBinding SuggestedOperationText}"
                                              TextWrapping="Wrap"
                                            />
                                            <TextBlock
                                              Classes="meta"
                                              Text="{CompiledBinding DetailText}"
                                              TextWrapping="Wrap"
                                            />
                                          </StackPanel>
                                        </Border>
                                      </DataTemplate>
                                    </ListBox.ItemTemplate>
                                  </ListBox>
                                </StackPanel>
                              </Border>

                              <Border Classes="metric" IsVisible="{CompiledBinding ShowLogbookFallbackLines}">
                                <StackPanel Spacing="8">
                                  <TextBlock Classes="h2" Text="Fallback" />
                                  <ItemsControl ItemsSource="{CompiledBinding LogbookResultLines}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate>
                                        <TextBlock Classes="meta" Text="{Binding}" TextWrapping="Wrap" />
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </StackPanel>
                              </Border>

                              <Border Classes="metric">
                                <StackPanel Spacing="8">
                                  <TextBlock Classes="h2" Text="Notes" />
                                  <ItemsControl ItemsSource="{CompiledBinding LogbookNotes}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate>
                                        <TextBlock Classes="meta" Text="{Binding}" TextWrapping="Wrap" />
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </StackPanel>
                              </Border>

                              <Border Classes="metric">
                                <StackPanel Spacing="8">
                                  <DockPanel LastChildFill="False">
                                    <TextBlock Classes="h2" DockPanel.Dock="Left" Text="Editor" />
                                    <Button
                                      Classes="action"
                                      Command="{CompiledBinding LoadLogbookCatalogCommand}"
                                      Content="Load Catalog"
                                      DockPanel.Dock="Right"
                                      IsEnabled="{CompiledBinding CanLoadLogbookCatalog}"
                                      IsVisible="{CompiledBinding LogbookMutationShowCatalogBrowser}"
                                    />
                                  </DockPanel>
                                  <TextBlock Classes="meta" Text="{CompiledBinding LogbookCatalogStatusText}" />
                                  <TextBlock
                                    Classes="meta"
                                    Text="{CompiledBinding LogbookCatalogSummaryText}"
                                    TextWrapping="Wrap"
                                  />
                                  <ComboBox
                                    ItemsSource="{CompiledBinding LogbookMutationOptions}"
                                    SelectedItem="{CompiledBinding SelectedLogbookMutationOption, Mode=TwoWay}"
                                  >
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="viewmodels:DebuggerLogbookMutationOption">
                                        <TextBlock Text="{CompiledBinding Label}" />
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                  <TextBlock
                                    Classes="meta"
                                    Text="{CompiledBinding LogbookMutationInputHintText}"
                                    TextWrapping="Wrap"
                                  />
                                  <Border
                                    Background="#151A20"
                                    BorderBrush="{DynamicResource SoftLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    IsVisible="{CompiledBinding LogbookMutationShowLiveStateInspector}"
                                    Padding="8,6"
                                  >
                                    <StackPanel Spacing="4">
                                      <TextBlock
                                        Classes="h3"
                                        Text="{CompiledBinding LogbookMutationLiveStateStatusText}"
                                      />
                                      <TextBlock
                                        Classes="meta"
                                        Text="{CompiledBinding LogbookMutationLiveStateSummaryText}"
                                        TextWrapping="Wrap"
                                      />
                                    </StackPanel>
                                  </Border>
                                  <TextBlock Classes="meta" Text="{CompiledBinding LogbookMutationStatusText}" />
                                  <TextBox
                                    IsVisible="{CompiledBinding LogbookMutationShowCatalogBrowser}"
                                    PlaceholderText="Filter local journal or source catalog"
                                    Text="{CompiledBinding LogbookCatalogFilterText, Mode=TwoWay}"
                                  />
                                  <ListBox
                                    Classes="sidebar"
                                    IsVisible="{CompiledBinding LogbookMutationShowCatalogBrowser}"
                                    ItemsSource="{CompiledBinding LogbookCatalogEntries}"
                                    MaxHeight="320"
                                    MinHeight="180"
                                    SelectedItem="{CompiledBinding SelectedLogbookCatalogEntry, Mode=TwoWay}"
                                  >
                                    <ListBox.ItemTemplate>
                                      <DataTemplate x:DataType="core:LogbookCatalogEntrySnapshot">
                                        <Border
                                          Margin="0,0,0,6"
                                          Background="#151A20"
                                          BorderBrush="{DynamicResource SoftLineBrush}"
                                          BorderThickness="1"
                                          CornerRadius="6"
                                          Padding="8,6"
                                        >
                                          <StackPanel Spacing="3">
                                            <DockPanel LastChildFill="False">
                                              <TextBlock
                                                Classes="h3"
                                                DockPanel.Dock="Left"
                                                Text="{CompiledBinding DisplayName}"
                                              />
                                              <Border
                                                Background="#21262D"
                                                CornerRadius="999"
                                                DockPanel.Dock="Right"
                                                Padding="8,3"
                                              >
                                                <TextBlock Classes="meta" Text="{CompiledBinding CategoryToken}" />
                                              </Border>
                                            </DockPanel>
                                            <TextBlock
                                              Classes="meta"
                                              Text="{CompiledBinding DetailText}"
                                              TextWrapping="Wrap"
                                            />
                                            <DockPanel LastChildFill="False">
                                              <TextBlock
                                                Classes="code"
                                                DockPanel.Dock="Left"
                                                Text="{CompiledBinding EntryId}"
                                              />
                                              <TextBlock
                                                Classes="meta"
                                                DockPanel.Dock="Right"
                                                Text="{CompiledBinding AuxiliaryId}"
                                              />
                                            </DockPanel>
                                          </StackPanel>
                                        </Border>
                                      </DataTemplate>
                                    </ListBox.ItemTemplate>
                                  </ListBox>
                                  <Grid ColumnDefinitions="1*,1*" ColumnSpacing="8">
                                    <TextBox
                                      IsEnabled="{CompiledBinding LogbookMutationRequiresEntry}"
                                      PlaceholderText="Entry id or selected catalog row"
                                      Text="{CompiledBinding LogbookMutationEntryText, Mode=TwoWay}"
                                    />
                                    <ComboBox
                                      Grid.Column="1"
                                      IsVisible="{CompiledBinding LogbookMutationShowValueSelector}"
                                      ItemsSource="{CompiledBinding LogbookMutationValueOptions}"
                                      SelectedItem="{CompiledBinding SelectedLogbookMutationValueOption, Mode=TwoWay}"
                                    >
                                      <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="viewmodels:DebuggerChoiceOption">
                                          <TextBlock Text="{CompiledBinding Label}" />
                                        </DataTemplate>
                                      </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <TextBox
                                      Grid.Column="1"
                                      IsVisible="{CompiledBinding LogbookMutationShowValueInput}"
                                      PlaceholderText="{CompiledBinding LogbookMutationValuePlaceholderText}"
                                      Text="{CompiledBinding LogbookMutationValueText, Mode=TwoWay}"
                                    />
                                  </Grid>
                                  <Grid ColumnDefinitions="1*,Auto,0.8*,Auto" ColumnSpacing="8">
                                    <TextBox
                                      IsVisible="{CompiledBinding LogbookMutationShowAuxiliaryInput}"
                                      PlaceholderText="{CompiledBinding LogbookMutationAuxiliaryPlaceholderText}"
                                      Text="{CompiledBinding LogbookMutationAuxiliaryText, Mode=TwoWay}"
                                    />
                                    <Button
                                      Grid.Column="1"
                                      Classes="secondary"
                                      Command="{CompiledBinding UseSelectedMobileForLogbookAuxiliaryCommand}"
                                      Content="Use Roster"
                                      IsEnabled="{CompiledBinding CanUseSelectedMobileRosterHandle}"
                                      IsVisible="{CompiledBinding LogbookMutationShowAuxiliaryRosterButton}"
                                    />
                                    <TextBox
                                      Grid.Column="2"
                                      PlaceholderText="Timeout ms"
                                      Text="{CompiledBinding LogbookMutationTimeoutText, Mode=TwoWay}"
                                    />
                                    <Button
                                      Grid.Column="3"
                                      Classes="action"
                                      Command="{CompiledBinding ApplyLogbookMutationCommand}"
                                      Content="Apply"
                                      IsEnabled="{CompiledBinding CanApplyLogbookMutation}"
                                    />
                                  </Grid>
                                  <ItemsControl ItemsSource="{CompiledBinding LogbookMutationResultLines}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate>
                                        <TextBlock Classes="meta" Text="{Binding}" TextWrapping="Wrap" />
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                  <Border
                                    Background="#151A20"
                                    BorderBrush="{DynamicResource SoftLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8,6"
                                  >
                                    <StackPanel Spacing="4">
                                      <TextBlock Classes="h3" Text="Result" />
                                      <TextBlock
                                        Classes="meta"
                                        Text="{CompiledBinding LogbookMutationDispatcherText}"
                                        TextWrapping="Wrap"
                                      />
                                      <TextBlock
                                        Classes="meta"
                                        Text="{CompiledBinding LogbookMutationExecutionDetailText}"
                                        TextWrapping="Wrap"
                                      />
                                      <TextBlock Classes="code" Text="{CompiledBinding LogbookMutationResultText}" />
                                    </StackPanel>
                                  </Border>
                                </StackPanel>
                              </Border>
                            </StackPanel>
                          </Grid>
                        </TabItem>
                      </TabControl>
                    </StackPanel>
                  </TabItem>

                  <TabItem Header="Runtime">
                    <TabControl Margin="0,12,0,0">
                      <TabItem Header="Reads">
                        <Border Classes="metric" Margin="0,0,0,0">
                          <StackPanel Spacing="8">
                            <TextBlock Classes="h2" Text="Runtime Reads" />
                            <Grid ColumnDefinitions="1.05*,Auto,Auto" ColumnSpacing="8">
                              <TextBox
                                PlaceholderText="Proto, name, object id, GUID, or palette search"
                                Text="{CompiledBinding PrototypeTokenText, Mode=TwoWay}"
                              />
                              <Button
                                Grid.Column="1"
                                Classes="secondary"
                                Command="{CompiledBinding BrowseLookupSupportedCatalogCommand}"
                                Content="Pick Supported"
                                IsEnabled="{CompiledBinding CanLoadGameDataCatalog}"
                              />
                              <Button
                                Grid.Column="2"
                                Classes="secondary"
                                Command="{CompiledBinding ResolvePrototypeCommand}"
                                Content="Resolve"
                              />
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                              <Button
                                Classes="secondary"
                                Command="{CompiledBinding BrowseLookupPrototypeCatalogCommand}"
                                Content="Pick Proto"
                                IsEnabled="{CompiledBinding CanLoadGameDataCatalog}"
                              />
                              <Button
                                Classes="secondary"
                                Command="{CompiledBinding BrowseLookupStaticObjectCatalogCommand}"
                                Content="Pick Placed"
                                IsEnabled="{CompiledBinding CanLoadGameDataCatalog}"
                              />
                            </StackPanel>
                            <TextBlock
                              Classes="meta"
                              Text="Pick Supported searches the local workspace across both prototype palette entries and placed mob or sector objects. Pick Proto stays in the object palette, while Pick Placed searches concrete mob or sector objects and can return exact GUID or object-id tokens. The same lookup box still accepts direct proto numbers, object ids, or GUIDs when you already know them."
                              TextWrapping="Wrap"
                            />
                            <controls:GameDataSupportedInputPanel
                              ApplyEntryCommand="{CompiledBinding ApplyLookupSupportedInputCommand}"
                              ApplyValueCommand="{CompiledBinding ApplyLookupSupportedInputValueCommand}"
                              BrowseCommand="{CompiledBinding BrowseLookupSupportedCatalogCommand}"
                              FilterText="{CompiledBinding LookupSupportedInputFilterText, Mode=TwoWay}"
                              State="{CompiledBinding LookupSupportedInputPanelState}"
                            />
                            <controls:GameDataQuickPickPanel IsVisible="{CompiledBinding LookupQuickPickVisible}" />
                            <TextBlock Classes="h3" Text="{CompiledBinding PrototypeStatusText}" />
                            <ItemsControl ItemsSource="{CompiledBinding PrototypeResultLines}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <TextBlock Classes="meta" Text="{Binding}" TextWrapping="Wrap" />
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBox
                              PlaceholderText="Adapter key"
                              Text="{CompiledBinding ReadAdapterKeyText, Mode=TwoWay}"
                            />
                            <TextBox
                              PlaceholderText="Args (player|42)"
                              Text="{CompiledBinding ReadArgumentsText, Mode=TwoWay}"
                            />
                            <Button
                              Classes="secondary"
                              Command="{CompiledBinding RunStructuredReadCommand}"
                              Content="Run Read"
                            />
                            <TextBlock Classes="h3" Text="{CompiledBinding ReadStatusText}" />
                            <ItemsControl ItemsSource="{CompiledBinding ReadResultLines}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <TextBlock Classes="meta" Text="{Binding}" TextWrapping="Wrap" />
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </StackPanel>
                        </Border>
                      </TabItem>

                      <TabItem Header="Symbols">
                        <Border Classes="metric" Margin="0,0,0,0">
                          <StackPanel Spacing="8">
                            <TextBlock Classes="h2" Text="Status / Symbols" />
                            <Button
                              Classes="secondary"
                              Command="{CompiledBinding InspectRuntimeStatusCommand}"
                              Content="Inspect"
                            />
                            <TextBlock Classes="h3" Text="{CompiledBinding RuntimeStatusText}" />
                            <ItemsControl ItemsSource="{CompiledBinding RuntimeStatusResultLines}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <TextBlock Classes="meta" Text="{Binding}" TextWrapping="Wrap" />
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Classes="h3" Text="Module symbols" />
                            <Grid ColumnDefinitions="1.2*,0.45*,0.5*,0.55*" ColumnSpacing="8">
                              <TextBox
                                PlaceholderText="Symbol filter"
                                Text="{CompiledBinding RuntimeModuleFilterText, Mode=TwoWay}"
                              />
                              <TextBox
                                Grid.Column="1"
                                PlaceholderText="Limit"
                                Text="{CompiledBinding RuntimeModuleLimitText, Mode=TwoWay}"
                              />
                              <CheckBox
                                Grid.Column="2"
                                Content="Duplicates only"
                                IsChecked="{CompiledBinding RuntimeModuleDuplicatesOnly, Mode=TwoWay}"
                              />
                              <Button
                                Grid.Column="3"
                                Classes="secondary"
                                Command="{CompiledBinding QueryRuntimeModuleSymbolsCommand}"
                                Content="Query"
                              />
                            </Grid>
                            <TextBlock Classes="h3" Text="{CompiledBinding RuntimeModuleStatusText}" />
                            <ItemsControl ItemsSource="{CompiledBinding RuntimeModuleResultLines}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <TextBlock Classes="meta" Text="{Binding}" TextWrapping="Wrap" />
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </StackPanel>
                        </Border>
                      </TabItem>

                      <TabItem Header="Scripts">
                        <Border Classes="metric" Margin="0,0,0,0">
                          <StackPanel Spacing="8">
                            <TextBlock Classes="h2" Text="Script Attachments" />
                            <TextBox
                              PlaceholderText="Handle token (player)"
                              Text="{CompiledBinding ScriptHandleTokenText, Mode=TwoWay}"
                            />
                            <TextBox
                              PlaceholderText="Attachment point"
                              Text="{CompiledBinding ScriptAttachmentPointText, Mode=TwoWay}"
                            />
                            <Button
                              Classes="secondary"
                              Command="{CompiledBinding ReadScriptAttachmentDiagnosticsCommand}"
                              Content="Read Attachment"
                            />
                            <TextBlock Classes="h3" Text="{CompiledBinding ScriptStatusText}" />
                            <ItemsControl ItemsSource="{CompiledBinding ScriptResultLines}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <TextBlock Classes="meta" Text="{Binding}" TextWrapping="Wrap" />
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </StackPanel>
                        </Border>
                      </TabItem>
                    </TabControl>
                  </TabItem>
                </TabControl>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <TabItem Header="Offline">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="2,12,2,2" Spacing="16">
                <TabControl>
                  <TabItem Header="Saves">
                    <StackPanel Margin="0,12,0,0" Spacing="16">
                      <TabControl>
                        <TabItem Header="Single Save">
                          <Grid Margin="0,0,0,0" ColumnDefinitions="0.92*,1.08*" ColumnSpacing="16">
                            <Border Classes="metric">
                              <StackPanel Spacing="8">
                                <TextBlock Classes="h2" Text="Single Save" />
                                <TextBox
                                  PlaceholderText="Save directory"
                                  Text="{CompiledBinding OfflineSaveDirectoryText, Mode=TwoWay}"
                                />
                                <TextBox
                                  PlaceholderText="Slot number (1 or 0001)"
                                  Text="{CompiledBinding OfflineSlotText, Mode=TwoWay}"
                                />
                                <Button
                                  Classes="action"
                                  Command="{CompiledBinding RunOfflineSaveDiagnosticsCommand}"
                                  Content="Load Save"
                                />
                                <TextBlock Classes="h3" Text="Explicit Files" />
                                <TextBox
                                  PlaceholderText=".gsi path"
                                  Text="{CompiledBinding OfflineSaveGsiPathText, Mode=TwoWay}"
                                />
                                <TextBox
                                  PlaceholderText=".tfai path"
                                  Text="{CompiledBinding OfflineSaveTfaiPathText, Mode=TwoWay}"
                                />
                                <TextBox
                                  PlaceholderText=".tfaf path"
                                  Text="{CompiledBinding OfflineSaveTfafPathText, Mode=TwoWay}"
                                />
                                <Button
                                  Classes="secondary"
                                  Command="{CompiledBinding RunOfflineSaveFileDiagnosticsCommand}"
                                  Content="Load Files"
                                />
                                <TextBlock Classes="h3" Text="{CompiledBinding OfflineSaveStatusText}" />
                                <ItemsControl ItemsSource="{CompiledBinding OfflineSaveHighlights}">
                                  <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                      <WrapPanel />
                                    </ItemsPanelTemplate>
                                  </ItemsControl.ItemsPanel>
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:DebuggerInsightCard">
                                      <Border
                                        Width="170"
                                        Margin="0,0,10,10"
                                        Background="#151A20"
                                        BorderBrush="{DynamicResource SoftLineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8,6"
                                      >
                                        <StackPanel Spacing="2">
                                          <TextBlock Classes="meta" Text="{CompiledBinding Label}" />
                                          <TextBlock Classes="h3" Text="{CompiledBinding Value}" />
                                          <TextBlock
                                            Classes="meta"
                                            Text="{CompiledBinding Detail}"
                                            TextWrapping="Wrap"
                                          />
                                        </StackPanel>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </StackPanel>
                            </Border>

                            <StackPanel Grid.Column="1" Spacing="16">
                              <Border Classes="metric" IsVisible="{CompiledBinding HasOfflineSaveSections}">
                                <StackPanel Spacing="8">
                                  <TextBlock Classes="h2" Text="Sections" />
                                  <ItemsControl ItemsSource="{CompiledBinding OfflineSaveSections}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate x:DataType="viewmodels:DebuggerInsightSection">
                                        <Border
                                          Margin="0,0,0,10"
                                          Background="#151A20"
                                          BorderBrush="{DynamicResource SoftLineBrush}"
                                          BorderThickness="1"
                                          CornerRadius="6"
                                          Padding="8,6"
                                        >
                                          <StackPanel Spacing="6">
                                            <TextBlock Classes="h3" Text="{CompiledBinding Title}" />
                                            <TextBlock
                                              Classes="meta"
                                              Text="{CompiledBinding Summary}"
                                              TextWrapping="Wrap"
                                            />
                                            <ItemsControl ItemsSource="{CompiledBinding Entries}">
                                              <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                  <TextBlock
                                                    Classes="meta"
                                                    Margin="0,0,0,4"
                                                    Text="{Binding}"
                                                    TextWrapping="Wrap"
                                                  />
                                                </DataTemplate>
                                              </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                          </StackPanel>
                                        </Border>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </StackPanel>
                              </Border>

                              <Border Classes="metric">
                                <StackPanel Spacing="8">
                                  <TextBlock Classes="h2" Text="Reference detail" />
                                  <ItemsControl ItemsSource="{CompiledBinding OfflineSaveResultLines}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate>
                                        <TextBlock Classes="meta" Text="{Binding}" TextWrapping="Wrap" />
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </StackPanel>
                              </Border>
                            </StackPanel>
                          </Grid>
                        </TabItem>

                        <TabItem Header="Compare Saves">
                          <Grid Margin="0,0,0,0" ColumnDefinitions="0.92*,1.08*" ColumnSpacing="16">
                            <Border Classes="metric">
                              <StackPanel Spacing="8">
                                <TextBlock Classes="h2" Text="Save Range Diff" />
                                <TextBox
                                  PlaceholderText="Save directory"
                                  Text="{CompiledBinding OfflineSaveDirectoryText, Mode=TwoWay}"
                                />
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                  <TextBox
                                    Grid.Column="0"
                                    PlaceholderText="First slot (0001)"
                                    Text="{CompiledBinding OfflineRangeFirstSlotText, Mode=TwoWay}"
                                  />
                                  <TextBox
                                    Grid.Column="1"
                                    PlaceholderText="Last slot (0005)"
                                    Text="{CompiledBinding OfflineRangeLastSlotText, Mode=TwoWay}"
                                  />
                                </Grid>
                                <Button
                                  Classes="action"
                                  Command="{CompiledBinding RunOfflineRangeDiagnosticsCommand}"
                                  Content="Compare"
                                />
                                <TextBlock Classes="h3" Text="{CompiledBinding OfflineRangeStatusText}" />
                                <ItemsControl ItemsSource="{CompiledBinding OfflineRangeHighlights}">
                                  <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                      <WrapPanel />
                                    </ItemsPanelTemplate>
                                  </ItemsControl.ItemsPanel>
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:DebuggerInsightCard">
                                      <Border
                                        Width="170"
                                        Margin="0,0,10,10"
                                        Background="#151A20"
                                        BorderBrush="{DynamicResource SoftLineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8,6"
                                      >
                                        <StackPanel Spacing="2">
                                          <TextBlock Classes="meta" Text="{CompiledBinding Label}" />
                                          <TextBlock Classes="h3" Text="{CompiledBinding Value}" />
                                          <TextBlock
                                            Classes="meta"
                                            Text="{CompiledBinding Detail}"
                                            TextWrapping="Wrap"
                                          />
                                        </StackPanel>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </StackPanel>
                            </Border>

                            <StackPanel Grid.Column="1" Spacing="16">
                              <Border Classes="metric" IsVisible="{CompiledBinding HasOfflineRangeSections}">
                                <StackPanel Spacing="8">
                                  <TextBlock Classes="h2" Text="Sections" />
                                  <ItemsControl ItemsSource="{CompiledBinding OfflineRangeSections}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate x:DataType="viewmodels:DebuggerInsightSection">
                                        <Border
                                          Margin="0,0,0,10"
                                          Background="#151A20"
                                          BorderBrush="{DynamicResource SoftLineBrush}"
                                          BorderThickness="1"
                                          CornerRadius="6"
                                          Padding="8,6"
                                        >
                                          <StackPanel Spacing="6">
                                            <TextBlock Classes="h3" Text="{CompiledBinding Title}" />
                                            <TextBlock
                                              Classes="meta"
                                              Text="{CompiledBinding Summary}"
                                              TextWrapping="Wrap"
                                            />
                                            <ItemsControl ItemsSource="{CompiledBinding Entries}">
                                              <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                  <TextBlock
                                                    Classes="meta"
                                                    Margin="0,0,0,4"
                                                    Text="{Binding}"
                                                    TextWrapping="Wrap"
                                                  />
                                                </DataTemplate>
                                              </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                          </StackPanel>
                                        </Border>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </StackPanel>
                              </Border>

                              <Border Classes="metric">
                                <StackPanel Spacing="8">
                                  <TextBlock Classes="h2" Text="Reference detail" />
                                  <ItemsControl ItemsSource="{CompiledBinding OfflineRangeResultLines}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate>
                                        <TextBlock Classes="meta" Text="{Binding}" TextWrapping="Wrap" />
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </StackPanel>
                              </Border>
                            </StackPanel>
                          </Grid>
                        </TabItem>
                      </TabControl>
                    </StackPanel>
                  </TabItem>

                  <TabItem Header="Reference">
                    <TabControl Margin="0,12,0,0">
                      <TabItem Header="Module">
                        <Border Classes="metric" Margin="0,0,0,0">
                          <StackPanel Spacing="8">
                            <TextBlock Classes="h2" Text="Module Symbols" />
                            <TextBox
                              PlaceholderText="Executable or DLL path"
                              Text="{CompiledBinding OfflineModulePathText, Mode=TwoWay}"
                            />
                            <TextBlock
                              Classes="meta"
                              Text="Use one offline executable or DLL path here when you want a standalone symbol lookup without an attached session."
                              TextWrapping="Wrap"
                            />
                            <Grid ColumnDefinitions="1.1*,0.45*,0.65*" ColumnSpacing="8">
                              <TextBox
                                PlaceholderText="Symbol filter"
                                Text="{CompiledBinding OfflineModuleFilterText, Mode=TwoWay}"
                              />
                              <TextBox
                                Grid.Column="1"
                                PlaceholderText="Limit"
                                Text="{CompiledBinding OfflineModuleLimitText, Mode=TwoWay}"
                              />
                              <CheckBox
                                Grid.Column="2"
                                Content="Duplicates only"
                                IsChecked="{CompiledBinding OfflineModuleDuplicatesOnly, Mode=TwoWay}"
                              />
                            </Grid>
                            <Button
                              Classes="secondary"
                              Command="{CompiledBinding QueryOfflineModuleSymbolsCommand}"
                              Content="Load Symbols"
                            />
                            <TextBlock Classes="h3" Text="{CompiledBinding OfflineModuleStatusText}" />
                            <ItemsControl ItemsSource="{CompiledBinding OfflineModuleResultLines}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <TextBlock Classes="meta" Text="{Binding}" TextWrapping="Wrap" />
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </StackPanel>
                        </Border>
                      </TabItem>

                      <TabItem Header="Source">
                        <Border Classes="metric" Margin="0,0,0,0">
                          <StackPanel Spacing="8">
                            <TextBlock Classes="h2" Text="Source Coverage" />
                            <TextBox
                              PlaceholderText="CE source root"
                              Text="{CompiledBinding OfflineSourceRootText, Mode=TwoWay}"
                            />
                            <Grid ColumnDefinitions="1.1*,0.8*,0.45*" ColumnSpacing="8">
                              <TextBox
                                PlaceholderText="Function filter"
                                Text="{CompiledBinding OfflineSourceFilterText, Mode=TwoWay}"
                              />
                              <TextBox
                                Grid.Column="1"
                                PlaceholderText="Area"
                                Text="{CompiledBinding OfflineSourceAreaText, Mode=TwoWay}"
                              />
                              <TextBox
                                Grid.Column="2"
                                PlaceholderText="Limit"
                                Text="{CompiledBinding OfflineSourceLimitText, Mode=TwoWay}"
                              />
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                              <CheckBox
                                Content="Missing only"
                                IsChecked="{CompiledBinding OfflineSourceMissingOnly, Mode=TwoWay}"
                              />
                              <CheckBox
                                Content="Covered only"
                                IsChecked="{CompiledBinding OfflineSourceCoveredOnly, Mode=TwoWay}"
                              />
                            </StackPanel>
                            <Button
                              Classes="secondary"
                              Command="{CompiledBinding RunOfflineCeSourceAuditCommand}"
                              Content="Load Coverage"
                            />
                            <TextBlock Classes="h3" Text="{CompiledBinding OfflineSourceStatusText}" />
                            <ItemsControl ItemsSource="{CompiledBinding OfflineSourceResultLines}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <TextBlock Classes="meta" Text="{Binding}" TextWrapping="Wrap" />
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </StackPanel>
                        </Border>
                      </TabItem>
                    </TabControl>
                  </TabItem>

                  <TabItem Header="Reports">
                    <TabControl Margin="0,12,0,0">
                      <TabItem Header="Templates">
                        <Border Classes="metric" Margin="0,0,0,0">
                          <StackPanel Spacing="8">
                            <TextBlock Classes="h2" Text="Report Templates" />
                            <ComboBox
                              ItemsSource="{CompiledBinding OfflineDumpTemplateOptions}"
                              SelectedItem="{CompiledBinding SelectedOfflineDumpTemplateOption, Mode=TwoWay}"
                            >
                              <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:DebuggerChoiceOption">
                                  <TextBlock Text="{CompiledBinding Label}" />
                                </DataTemplate>
                              </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBox
                              PlaceholderText="File path or save directory"
                              Text="{CompiledBinding OfflineDumpPathText, Mode=TwoWay}"
                            />
                            <Button
                              Classes="action"
                              Command="{CompiledBinding RunOfflineDumpTemplateCommand}"
                              Content="Render"
                            />
                            <TextBlock Classes="h3" Text="{CompiledBinding OfflineDumpStatusText}" />
                            <ItemsControl ItemsSource="{CompiledBinding OfflineDumpHighlights}">
                              <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                  <WrapPanel />
                                </ItemsPanelTemplate>
                              </ItemsControl.ItemsPanel>
                              <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:DebuggerInsightCard">
                                  <Border
                                    Width="170"
                                    Margin="0,0,10,10"
                                    Background="#151A20"
                                    BorderBrush="{DynamicResource SoftLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8,6"
                                  >
                                    <StackPanel Spacing="2">
                                      <TextBlock Classes="meta" Text="{CompiledBinding Label}" />
                                      <TextBlock Classes="h3" Text="{CompiledBinding Value}" />
                                      <TextBlock Classes="meta" Text="{CompiledBinding Detail}" TextWrapping="Wrap" />
                                    </StackPanel>
                                  </Border>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ItemsControl
                              IsVisible="{CompiledBinding HasOfflineDumpSections}"
                              ItemsSource="{CompiledBinding OfflineDumpSections}"
                            >
                              <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:DebuggerInsightSection">
                                  <Border
                                    Margin="0,0,0,10"
                                    Background="#151A20"
                                    BorderBrush="{DynamicResource SoftLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8,6"
                                  >
                                    <StackPanel Spacing="6">
                                      <TextBlock Classes="h3" Text="{CompiledBinding Title}" />
                                      <TextBlock Classes="meta" Text="{CompiledBinding Summary}" TextWrapping="Wrap" />
                                      <ItemsControl ItemsSource="{CompiledBinding Entries}">
                                        <ItemsControl.ItemTemplate>
                                          <DataTemplate>
                                            <TextBlock
                                              Classes="meta"
                                              Margin="0,0,0,4"
                                              Text="{Binding}"
                                              TextWrapping="Wrap"
                                            />
                                          </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                      </ItemsControl>
                                    </StackPanel>
                                  </Border>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ItemsControl ItemsSource="{CompiledBinding OfflineDumpResultLines}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <TextBlock Classes="meta" Text="{Binding}" TextWrapping="Wrap" />
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </StackPanel>
                        </Border>
                      </TabItem>

                      <TabItem Header="Report Text">
                        <Border Classes="metric" Margin="0,0,0,0">
                          <StackPanel Spacing="8">
                            <TextBlock Classes="h2" Text="Report Text" />
                            <TextBox
                              AcceptsReturn="True"
                              FontFamily="Cascadia Code, Consolas"
                              IsReadOnly="True"
                              MinHeight="520"
                              Text="{CompiledBinding OfflineDumpOutputText}"
                              TextWrapping="Wrap"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            />
                          </StackPanel>
                        </Border>
                      </TabItem>
                    </TabControl>
                  </TabItem>
                </TabControl>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <TabItem Header="Watch">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="2,12,2,2" Spacing="16">
                <TabControl>
                  <TabItem Header="Live">
                    <Grid Margin="0,12,0,0" ColumnDefinitions="1.1*,0.9*" ColumnSpacing="16">
                      <Border Classes="metric">
                        <StackPanel Spacing="8">
                          <TextBlock Classes="h2" Text="Live Watch" />
                          <TextBlock Classes="meta" Text="{CompiledBinding TimelineStatusText}" />
                          <ComboBox
                            ItemsSource="{CompiledBinding WatchPresetOptions}"
                            SelectedItem="{CompiledBinding SelectedWatchPresetOption, Mode=TwoWay}"
                          >
                            <ComboBox.ItemTemplate>
                              <DataTemplate x:DataType="core:TimelinePresetDescriptor">
                                <TextBlock Text="{CompiledBinding DisplayName}" />
                              </DataTemplate>
                            </ComboBox.ItemTemplate>
                          </ComboBox>
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button
                              Classes="action"
                              Command="{CompiledBinding StartTimelineWatchCommand}"
                              Content="Start"
                              IsEnabled="{CompiledBinding CanStartTimelineWatch}"
                            />
                            <Button
                              Classes="secondary"
                              Command="{CompiledBinding RefreshTimelineWatchCommand}"
                              Content="Poll"
                            />
                            <Button
                              Classes="secondary"
                              Command="{CompiledBinding StopTimelineWatchCommand}"
                              Content="Stop"
                            />
                          </StackPanel>
                          <TextBlock
                            Classes="meta"
                            Text="{CompiledBinding LiveTimelineSummaryText}"
                            TextWrapping="Wrap"
                          />
                          <ListBox
                            Classes="sidebar"
                            ItemsSource="{CompiledBinding LiveTimelineEvents}"
                            SelectedItem="{CompiledBinding SelectedLiveTimelineEvent, Mode=TwoWay}"
                          >
                            <ListBox.ItemTemplate>
                              <DataTemplate x:DataType="core:WatchEventSnapshot">
                                <Border
                                  Margin="0,0,0,6"
                                  Background="#151A20"
                                  BorderBrush="{DynamicResource SoftLineBrush}"
                                  BorderThickness="1"
                                  CornerRadius="6"
                                  Padding="8,6"
                                >
                                  <StackPanel Spacing="3">
                                    <DockPanel>
                                      <TextBlock
                                        DockPanel.Dock="Left"
                                        Classes="h3"
                                        Text="{CompiledBinding SemanticEvent}"
                                      />
                                      <Border
                                        DockPanel.Dock="Right"
                                        Background="#21262D"
                                        CornerRadius="999"
                                        Padding="8,3"
                                      >
                                        <TextBlock Classes="meta" Text="{CompiledBinding Sequence}" />
                                      </Border>
                                    </DockPanel>
                                    <TextBlock Classes="code" Text="{CompiledBinding Signature}" />
                                    <TextBlock Classes="code" Text="{CompiledBinding CallerAddress}" />
                                    <TextBlock Classes="meta" Text="{CompiledBinding SuggestedHandleHex}" />
                                  </StackPanel>
                                </Border>
                              </DataTemplate>
                            </ListBox.ItemTemplate>
                          </ListBox>
                        </StackPanel>
                      </Border>

                      <Border Classes="metric" Grid.Column="1">
                        <StackPanel Spacing="8">
                          <TextBlock Classes="h2" Text="Selection" />
                          <TextBlock Classes="h3" Text="{CompiledBinding SelectedLiveTimelineEventSummaryText}" />
                          <TextBlock
                            Classes="meta"
                            Text="{CompiledBinding SelectedLiveTimelineEventHandleSummaryText}"
                            TextWrapping="Wrap"
                          />
                        </StackPanel>
                      </Border>
                    </Grid>
                  </TabItem>

                  <TabItem Header="Presets">
                    <Grid Margin="0,12,0,0" ColumnDefinitions="1.05*,0.95*" ColumnSpacing="16">
                      <Border Classes="metric">
                        <StackPanel Spacing="8">
                          <TextBlock Classes="h2" Text="Presets" />
                          <ItemsControl ItemsSource="{CompiledBinding FeaturedTimelinePresets}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate x:DataType="viewmodels:DebuggerTimelineCard">
                                <Border
                                  Margin="0,0,0,6"
                                  Background="#151A20"
                                  BorderBrush="{DynamicResource SoftLineBrush}"
                                  BorderThickness="1"
                                  CornerRadius="6"
                                  Padding="8,6"
                                >
                                  <StackPanel Spacing="3">
                                    <DockPanel>
                                      <TextBlock
                                        DockPanel.Dock="Left"
                                        Classes="h3"
                                        Text="{CompiledBinding DisplayName}"
                                      />
                                      <Border
                                        DockPanel.Dock="Right"
                                        Background="#3A311A"
                                        CornerRadius="999"
                                        IsVisible="{CompiledBinding UsesHighVolumeHooks}"
                                        Padding="8,3"
                                      >
                                        <TextBlock Classes="meta" Text="High volume" />
                                      </Border>
                                    </DockPanel>
                                    <TextBlock Classes="code" Text="{CompiledBinding HookSummary}" />
                                  </StackPanel>
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </Border>

                      <Border Classes="metric" Grid.Column="1">
                        <StackPanel Spacing="8">
                          <TextBlock Classes="h2" Text="Custom Profiles" />
                          <ItemsControl ItemsSource="{CompiledBinding FeaturedAdvancedProfiles}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate x:DataType="viewmodels:DebuggerAdvancedProfileCard">
                                <Border
                                  Margin="0,0,0,6"
                                  Background="#151A20"
                                  BorderBrush="{DynamicResource SoftLineBrush}"
                                  BorderThickness="1"
                                  CornerRadius="6"
                                  Padding="8,6"
                                >
                                  <StackPanel Spacing="3">
                                    <TextBlock Classes="h3" Text="{CompiledBinding Key}" />
                                    <TextBlock Classes="meta" Text="{CompiledBinding HookSummary}" />
                                  </StackPanel>
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </Border>
                    </Grid>
                  </TabItem>
                </TabControl>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <TabItem Header="Act">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="2,12,2,2" Spacing="16">
                <TabControl SelectedIndex="{CompiledBinding SelectedActTabIndex, Mode=TwoWay}">
                  <TabItem Header="Guided">
                    <Border Margin="0,12,0,0" Classes="metric">
                      <StackPanel Spacing="8">
                        <TextBlock Classes="h2" Text="Guided Action" />
                        <TextBlock Classes="meta" Text="{CompiledBinding GuidedActionStatusText}" />
                        <ComboBox
                          ItemsSource="{CompiledBinding GuidedActionOptions}"
                          SelectedItem="{CompiledBinding SelectedGuidedActionOption, Mode=TwoWay}"
                        >
                          <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="core:GuidedActionDescriptor">
                              <TextBlock Text="{CompiledBinding DisplayName}" />
                            </DataTemplate>
                          </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock
                          Classes="meta"
                          Text="{CompiledBinding GuidedActionTargetSummaryText}"
                          TextWrapping="Wrap"
                        />
                        <Grid ColumnDefinitions="1.1*,Auto,0.65*,0.65*,Auto" ColumnSpacing="8">
                          <TextBox
                            PlaceholderText="{CompiledBinding GuidedActionTravelerPlaceholderText}"
                            Text="{CompiledBinding GuidedActionTravelerText, Mode=TwoWay}"
                          />
                          <Button
                            Grid.Column="1"
                            Classes="secondary"
                            Command="{CompiledBinding UseSelectedMobileForGuidedActionCommand}"
                            Content="Use Roster"
                            IsEnabled="{CompiledBinding CanUseSelectedMobileRosterHandle}"
                          />
                          <TextBox
                            Grid.Column="2"
                            IsVisible="{CompiledBinding GuidedActionShowTileInputs}"
                            PlaceholderText="{CompiledBinding GuidedActionTileXPlaceholderText}"
                            Text="{CompiledBinding GuidedActionTileXText, Mode=TwoWay}"
                          />
                          <TextBox
                            Grid.Column="3"
                            IsVisible="{CompiledBinding GuidedActionShowTileInputs}"
                            PlaceholderText="{CompiledBinding GuidedActionTileYPlaceholderText}"
                            Text="{CompiledBinding GuidedActionTileYText, Mode=TwoWay}"
                          />
                          <Button
                            Grid.Column="4"
                            Classes="secondary"
                            Command="{CompiledBinding BrowseGuidedActionWorldCatalogCommand}"
                            Content="Pick World"
                            IsEnabled="{CompiledBinding CanLoadGameDataCatalog}"
                            IsVisible="{CompiledBinding GuidedActionShowTileInputs}"
                          />
                        </Grid>
                        <TextBlock
                          Classes="meta"
                          Text="Use Roster copies the currently selected mobile from the Mobiles tab into the traveler field. Pick World now searches the local workspace right here so teleport targets can come from known map data instead of manual coordinates."
                          TextWrapping="Wrap"
                        />
                        <controls:GameDataSupportedInputPanel
                          ApplyEntryCommand="{CompiledBinding ApplyGuidedActionWorldSupportedInputCommand}"
                          ApplyValueCommand="{CompiledBinding ApplyGuidedActionWorldSupportedInputValueCommand}"
                          BrowseCommand="{CompiledBinding BrowseGuidedActionWorldCatalogCommand}"
                          FilterText="{CompiledBinding GuidedActionWorldSupportedInputFilterText, Mode=TwoWay}"
                          IsVisible="{CompiledBinding GuidedActionWorldSupportedInputPanelVisible}"
                          State="{CompiledBinding GuidedActionWorldSupportedInputPanelState}"
                        />
                        <controls:GameDataQuickPickPanel IsVisible="{CompiledBinding GuidedActionQuickPickVisible}" />
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                          <TextBox
                            IsVisible="{CompiledBinding GuidedActionShowMapIdInput}"
                            PlaceholderText="{CompiledBinding GuidedActionMapIdPlaceholderText}"
                            Text="{CompiledBinding GuidedActionMapIdText, Mode=TwoWay}"
                          />
                          <TextBox
                            Grid.Column="1"
                            IsVisible="{CompiledBinding GuidedActionShowFlagsInput}"
                            PlaceholderText="{CompiledBinding GuidedActionFlagsPlaceholderText}"
                            Text="{CompiledBinding GuidedActionFlagsText, Mode=TwoWay}"
                          />
                          <TextBox
                            Grid.Column="2"
                            PlaceholderText="Timeout ms"
                            Text="{CompiledBinding GuidedActionTimeoutText, Mode=TwoWay}"
                          />
                        </Grid>
                        <Button
                          Classes="action"
                          Command="{CompiledBinding InvokeGuidedActionCommand}"
                          Content="Run"
                          IsEnabled="{CompiledBinding CanInvokeGuidedAction}"
                        />
                        <Border
                          Background="#151A20"
                          BorderBrush="{DynamicResource SoftLineBrush}"
                          BorderThickness="1"
                          CornerRadius="6"
                          Padding="8,6"
                        >
                          <StackPanel Spacing="4">
                            <TextBlock Classes="h3" Text="Result" />
                            <TextBlock
                              Classes="meta"
                              Text="{CompiledBinding GuidedActionDispatcherText}"
                              TextWrapping="Wrap"
                            />
                            <TextBlock
                              Classes="meta"
                              Text="{CompiledBinding GuidedActionExecutionDetailText}"
                              TextWrapping="Wrap"
                            />
                            <TextBlock Classes="code" Text="{CompiledBinding GuidedActionResultText}" />
                          </StackPanel>
                        </Border>
                      </StackPanel>
                    </Border>
                  </TabItem>

                  <TabItem Header="Inventory">
                    <Grid Margin="0,12,0,0" ColumnDefinitions="320,*" ColumnSpacing="16">
                      <Border Classes="metric">
                        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8">
                          <StackPanel Spacing="8">
                            <TextBlock Classes="h2" Text="Owners" />
                            <TextBlock
                              Classes="meta"
                              Text="{CompiledBinding InventoryOwnerStatusText}"
                              TextWrapping="Wrap"
                            />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                              <Button
                                Classes="secondary"
                                Command="{CompiledBinding RefreshMobileRosterCommand}"
                                Content="Refresh Characters"
                                IsEnabled="{CompiledBinding CanRefreshMobileRoster}"
                              />
                              <Button
                                Classes="secondary"
                                Command="{CompiledBinding RefreshInventoryLiveStateCommand}"
                                Content="Refresh Items"
                                IsEnabled="{CompiledBinding CanRefreshInventoryLiveState}"
                              />
                            </StackPanel>
                          </StackPanel>

                          <ListBox
                            Grid.Row="1"
                            Classes="sidebar"
                            ItemsSource="{CompiledBinding InventoryOwnerEntries}"
                            SelectedItem="{CompiledBinding SelectedInventoryOwnerEntry, Mode=TwoWay}"
                          >
                            <ListBox.ItemTemplate>
                              <DataTemplate x:DataType="viewmodels:InventoryOwnerEntry">
                                <Border
                                  Margin="0,0,0,6"
                                  Background="#151A20"
                                  BorderBrush="{DynamicResource SoftLineBrush}"
                                  BorderThickness="1"
                                  CornerRadius="6"
                                  Padding="8,6"
                                >
                                  <StackPanel Spacing="3">
                                    <DockPanel LastChildFill="False">
                                      <TextBlock
                                        Classes="h3"
                                        DockPanel.Dock="Left"
                                        Text="{CompiledBinding DisplayText}"
                                      />
                                      <Border
                                        Background="#21262D"
                                        CornerRadius="999"
                                        DockPanel.Dock="Right"
                                        Padding="8,2"
                                      >
                                        <TextBlock Classes="meta" Text="{CompiledBinding RoleText}" />
                                      </Border>
                                    </DockPanel>
                                    <TextBlock
                                      Classes="meta"
                                      Text="{CompiledBinding SummaryText}"
                                      TextWrapping="Wrap"
                                    />
                                    <TextBlock Classes="code" Text="{CompiledBinding HandleTokenText}" />
                                  </StackPanel>
                                </Border>
                              </DataTemplate>
                            </ListBox.ItemTemplate>
                          </ListBox>

                          <TextBlock
                            Grid.Row="2"
                            Classes="meta"
                            Text="{CompiledBinding InventoryLiveStatusText}"
                            TextWrapping="Wrap"
                          />
                        </Grid>
                      </Border>

                      <StackPanel Grid.Column="1" Spacing="16">
                        <Border Classes="metric">
                          <StackPanel Spacing="8">
                            <TextBlock Classes="h2" Text="Selected Inventory" />
                            <TextBlock Classes="meta" Text="{CompiledBinding InventoryLiveStatusText}" />
                            <TextBlock
                              Classes="meta"
                              Text="{CompiledBinding InventoryLiveSummaryText}"
                              TextWrapping="Wrap"
                            />
                            <Grid ColumnDefinitions="0.95*,1.2*,0.55*,Auto" ColumnSpacing="8">
                              <TextBox
                                PlaceholderText="Owner handle or player"
                                Text="{CompiledBinding InventoryOwnerTokenText, Mode=TwoWay}"
                              />
                              <TextBox
                                Grid.Column="1"
                                PlaceholderText="Module item token"
                                Text="{CompiledBinding InventoryPrototypeTokenText, Mode=TwoWay}"
                              />
                              <TextBox
                                Grid.Column="2"
                                PlaceholderText="Slot"
                                Text="{CompiledBinding InventoryLocationText, Mode=TwoWay}"
                              />
                              <Button
                                Grid.Column="3"
                                Classes="action"
                                Command="{CompiledBinding CreateInventoryItemCommand}"
                                Content="Create Item"
                                IsEnabled="{CompiledBinding CanCreateInventoryItem}"
                              />
                            </Grid>
                            <controls:GameDataSupportedInputPanel
                              ApplyEntryCommand="{CompiledBinding ApplyInventorySupportedInputCommand}"
                              ApplyValueCommand="{CompiledBinding ApplyInventorySupportedInputValueCommand}"
                              BrowseCommand="{CompiledBinding BrowseInventorySupportedCatalogCommand}"
                              FilterText="{CompiledBinding InventorySupportedInputFilterText, Mode=TwoWay}"
                              State="{CompiledBinding InventorySupportedInputPanelState}"
                            />
                            <controls:GameDataQuickPickPanel IsVisible="{CompiledBinding InventoryQuickPickVisible}" />
                          </StackPanel>
                        </Border>

                        <Border Classes="metric">
                          <StackPanel Spacing="8">
                            <DockPanel LastChildFill="False">
                              <TextBlock Classes="h2" DockPanel.Dock="Left" Text="Live Items" />
                              <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
                                <Button
                                  Classes="secondary"
                                  Command="{CompiledBinding UseSelectedInventoryLiveItemHandleCommand}"
                                  Content="Use Selected"
                                  IsEnabled="{CompiledBinding CanUseSelectedInventoryLiveItemHandle}"
                                />
                                <Button
                                  Classes="secondary"
                                  Command="{CompiledBinding InspectSelectedInventoryLiveItemCommand}"
                                  Content="Inspect"
                                  IsEnabled="{CompiledBinding CanInspectSelectedInventoryLiveItem}"
                                />
                              </StackPanel>
                            </DockPanel>

                            <ListBox
                              Classes="sidebar"
                              ItemsSource="{CompiledBinding InventoryLiveItemEntries}"
                              MaxHeight="360"
                              SelectedItem="{CompiledBinding SelectedInventoryLiveItemEntry, Mode=TwoWay}"
                            >
                              <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:InventoryLiveItemEntry">
                                  <Border
                                    Margin="0,0,0,6"
                                    Background="#151A20"
                                    BorderBrush="{DynamicResource SoftLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8,6"
                                  >
                                    <StackPanel Spacing="3">
                                      <DockPanel LastChildFill="False">
                                        <TextBlock
                                          Classes="h3"
                                          DockPanel.Dock="Left"
                                          Text="{CompiledBinding DisplayText}"
                                        />
                                        <Border
                                          Background="#21262D"
                                          CornerRadius="999"
                                          DockPanel.Dock="Right"
                                          Padding="8,2"
                                        >
                                          <TextBlock Classes="meta" Text="{CompiledBinding SlotLabelText}" />
                                        </Border>
                                      </DockPanel>
                                      <TextBlock
                                        Classes="meta"
                                        Text="{CompiledBinding PrototypeText}"
                                        TextWrapping="Wrap"
                                      />
                                      <TextBlock Classes="code" Text="{CompiledBinding HandleText}" />
                                      <TextBlock
                                        Classes="meta"
                                        Text="{CompiledBinding SummaryText}"
                                        TextWrapping="Wrap"
                                      />
                                    </StackPanel>
                                  </Border>
                                </DataTemplate>
                              </ListBox.ItemTemplate>
                            </ListBox>

                            <Grid ColumnDefinitions="1.1*,0.7*,Auto,Auto" ColumnSpacing="8">
                              <TextBox
                                PlaceholderText="Item handle"
                                Text="{CompiledBinding InventoryItemHandleText, Mode=TwoWay}"
                              />
                              <TextBox
                                Grid.Column="1"
                                PlaceholderText="Timeout ms"
                                Text="{CompiledBinding InventoryTimeoutText, Mode=TwoWay}"
                              />
                              <Button
                                Grid.Column="2"
                                Classes="secondary"
                                Command="{CompiledBinding DestroyInventoryItemCommand}"
                                Content="Destroy Item"
                                IsEnabled="{CompiledBinding CanDestroyInventoryItem}"
                              />
                              <Button
                                Grid.Column="3"
                                Classes="secondary"
                                Command="{CompiledBinding RefreshInventoryLiveStateCommand}"
                                Content="Refresh"
                                IsEnabled="{CompiledBinding CanRefreshInventoryLiveState}"
                              />
                            </Grid>

                            <TextBlock Classes="h3" Text="Last Inventory Action" />
                            <TextBlock Classes="meta" Text="{CompiledBinding InventoryEditorStatusText}" />
                            <ItemsControl ItemsSource="{CompiledBinding InventoryEditorResultLines}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <TextBlock Classes="meta" Text="{Binding}" TextWrapping="Wrap" />
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </StackPanel>
                        </Border>
                      </StackPanel>
                    </Grid>
                  </TabItem>

                  <TabItem Header="Mobiles">
                    <Grid Margin="0,12,0,0" ColumnDefinitions="1.05*,0.95*" ColumnSpacing="16">
                      <Border Classes="metric">
                        <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="8">
                          <TextBlock Classes="h2" Text="Live Mobile Roster" />

                          <StackPanel Grid.Row="1" Spacing="8">
                            <TextBlock Classes="meta" Text="{CompiledBinding MobileRosterStatusText}" />
                            <Grid ColumnDefinitions="1.2*,Auto,Auto" ColumnSpacing="8">
                              <TextBox
                                PlaceholderText="Filter by handle, proto, type, or label"
                                Text="{CompiledBinding MobileRosterFilterText, Mode=TwoWay}"
                              />
                              <CheckBox
                                Grid.Column="1"
                                Content="Auto refresh"
                                IsChecked="{CompiledBinding MobileRosterAutoRefresh, Mode=TwoWay}"
                                VerticalAlignment="Center"
                              />
                              <Button
                                Grid.Column="2"
                                Classes="action"
                                Command="{CompiledBinding RefreshMobileRosterCommand}"
                                Content="Refresh"
                                IsEnabled="{CompiledBinding CanRefreshMobileRoster}"
                              />
                            </Grid>
                            <TextBlock
                              Classes="meta"
                              Text="{CompiledBinding MobileRosterSummaryText}"
                              TextWrapping="Wrap"
                            />
                          </StackPanel>

                          <ListBox
                            Grid.Row="2"
                            Classes="sidebar"
                            ItemsSource="{CompiledBinding MobileRosterEntries}"
                            SelectedItem="{CompiledBinding SelectedMobileRosterEntry, Mode=TwoWay}"
                          >
                            <ListBox.ItemTemplate>
                              <DataTemplate x:DataType="core:MobileRosterEntrySnapshot">
                                <Border
                                  Margin="0,0,0,6"
                                  Background="#151A20"
                                  BorderBrush="{DynamicResource SoftLineBrush}"
                                  BorderThickness="1"
                                  CornerRadius="6"
                                  Padding="8,6"
                                >
                                  <StackPanel Spacing="3">
                                    <DockPanel LastChildFill="False">
                                      <TextBlock
                                        Classes="h3"
                                        DockPanel.Dock="Left"
                                        Text="{CompiledBinding DisplayText}"
                                      />
                                      <Border
                                        Background="#21262D"
                                        CornerRadius="999"
                                        DockPanel.Dock="Right"
                                        Padding="8,3"
                                      >
                                        <TextBlock Classes="meta" Text="{CompiledBinding ObjectTypeText}" />
                                      </Border>
                                    </DockPanel>
                                    <TextBlock Classes="meta" Text="{CompiledBinding StatusText}" />
                                    <TextBlock Classes="meta" Text="{CompiledBinding PrototypeText}" />
                                    <TextBlock Classes="code" Text="{CompiledBinding HandleHex}" />
                                  </StackPanel>
                                </Border>
                              </DataTemplate>
                            </ListBox.ItemTemplate>
                          </ListBox>

                          <TextBlock Grid.Row="3" Classes="meta" Text="{CompiledBinding MobileMutationStatusText}" />
                        </Grid>
                      </Border>

                      <StackPanel Grid.Column="1" Spacing="16">
                        <Border Classes="metric">
                          <StackPanel Spacing="8">
                            <TextBlock Classes="h2" Text="Selected Mobile" />
                            <TextBlock Classes="meta" Text="{CompiledBinding MobileMutationStatusText}" />
                            <ContentControl Content="{CompiledBinding SelectedMobileRosterEntry}">
                              <ContentControl.ContentTemplate>
                                <DataTemplate x:DataType="core:MobileRosterEntrySnapshot">
                                  <Border
                                    Background="#151A20"
                                    BorderBrush="{DynamicResource SoftLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8,6"
                                  >
                                    <StackPanel Spacing="3">
                                      <TextBlock Classes="h3" Text="{CompiledBinding DisplayText}" />
                                      <TextBlock
                                        Classes="meta"
                                        Text="{CompiledBinding PrototypeText}"
                                        TextWrapping="Wrap"
                                      />
                                      <TextBlock Classes="meta" Text="{CompiledBinding StatusText}" />
                                      <TextBlock Classes="code" Text="{CompiledBinding HandleHex}" />
                                    </StackPanel>
                                  </Border>
                                </DataTemplate>
                              </ContentControl.ContentTemplate>
                            </ContentControl>
                            <Grid ColumnDefinitions="1.2*,Auto,Auto,Auto" ColumnSpacing="8">
                              <TextBox
                                PlaceholderText="Target handle or player"
                                Text="{CompiledBinding MobileTargetHandleText, Mode=TwoWay}"
                              />
                              <Button
                                Grid.Column="1"
                                Classes="action"
                                Command="{CompiledBinding InspectSelectedMobileCommand}"
                                Content="Inspect Details"
                                IsEnabled="{CompiledBinding CanInspectSelectedMobile}"
                              />
                              <Button
                                Grid.Column="2"
                                Classes="secondary"
                                Command="{CompiledBinding KillMobileCommand}"
                                Content="Kill"
                                IsEnabled="{CompiledBinding CanKillMobile}"
                              />
                              <Button
                                Grid.Column="3"
                                Classes="secondary"
                                Command="{CompiledBinding DespawnMobileCommand}"
                                Content="Despawn"
                                IsEnabled="{CompiledBinding CanDespawnMobile}"
                              />
                            </Grid>
                          </StackPanel>
                        </Border>

                        <Border Classes="metric">
                          <StackPanel Spacing="8">
                            <TextBlock Classes="h2" Text="Edit Base Stat" />
                            <Grid ColumnDefinitions="1.1*,0.8*,0.7*,Auto" ColumnSpacing="8">
                              <TextBox
                                PlaceholderText="Stat token (strength, level, alignment)"
                                Text="{CompiledBinding MobileStatTokenText, Mode=TwoWay}"
                              />
                              <TextBox
                                Grid.Column="1"
                                PlaceholderText="Value"
                                Text="{CompiledBinding MobileStatValueText, Mode=TwoWay}"
                              />
                              <TextBox
                                Grid.Column="2"
                                PlaceholderText="Timeout ms"
                                Text="{CompiledBinding MobileMutationTimeoutText, Mode=TwoWay}"
                              />
                              <Button
                                Grid.Column="3"
                                Classes="action"
                                Command="{CompiledBinding SetMobileStatCommand}"
                                Content="Set Stat"
                                IsEnabled="{CompiledBinding CanSetMobileStat}"
                              />
                            </Grid>
                          </StackPanel>
                        </Border>

                        <Border Classes="metric">
                          <StackPanel Spacing="12">
                            <TextBlock Classes="h2" Text="Create Mobile or Object" />
                            <TextBlock Classes="meta" Text="{CompiledBinding GameDataCatalogPresetSourceText}" />
                            <Grid ColumnDefinitions="1.0*,Auto,1.0*,Auto" ColumnSpacing="8">
                              <TextBox
                                PlaceholderText="Anchor handle or player"
                                Text="{CompiledBinding MobileSpawnAnchorTokenText, Mode=TwoWay}"
                              />
                              <Button
                                Grid.Column="1"
                                Classes="secondary"
                                Command="{CompiledBinding UseSelectedMobileForSpawnAnchorCommand}"
                                Content="Use Roster"
                                IsEnabled="{CompiledBinding CanUseSelectedMobileRosterHandle}"
                              />
                              <TextBox
                                Grid.Column="2"
                                PlaceholderText="Module spawn token"
                                Text="{CompiledBinding MobileSpawnPrototypeTokenText, Mode=TwoWay}"
                              />
                              <Button
                                Grid.Column="3"
                                Classes="action"
                                Command="{CompiledBinding SpawnMobileCommand}"
                                Content="Create"
                                IsEnabled="{CompiledBinding CanSpawnMobile}"
                              />
                            </Grid>
                            <controls:GameDataSupportedInputPanel
                              ApplyEntryCommand="{CompiledBinding ApplySpawnSupportedInputCommand}"
                              ApplyValueCommand="{CompiledBinding ApplySpawnSupportedInputValueCommand}"
                              BrowseCommand="{CompiledBinding BrowseSpawnSupportedCatalogCommand}"
                              FilterText="{CompiledBinding SpawnSupportedInputFilterText, Mode=TwoWay}"
                              State="{CompiledBinding SpawnSupportedInputPanelState}"
                            />
                            <controls:GameDataQuickPickPanel IsVisible="{CompiledBinding SpawnQuickPickVisible}" />
                          </StackPanel>
                        </Border>

                        <Border Classes="metric">
                          <StackPanel Spacing="8">
                            <TextBlock Classes="h2" Text="Last Mobile Action" />
                            <ItemsControl ItemsSource="{CompiledBinding MobileMutationResultLines}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <TextBlock Classes="meta" Text="{Binding}" TextWrapping="Wrap" />
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </StackPanel>
                        </Border>
                      </StackPanel>
                    </Grid>
                  </TabItem>

                  <TabItem Header="Spell/Tech">
                    <Grid
                      Margin="0,12,0,0"
                      RowDefinitions="Auto,*,Auto"
                      ColumnDefinitions="1.05*,0.95*"
                      ColumnSpacing="16"
                      RowSpacing="16"
                    >
                      <Border Grid.ColumnSpan="2" Classes="metric">
                        <StackPanel Spacing="8">
                          <DockPanel LastChildFill="False">
                            <TextBlock Classes="h2" DockPanel.Dock="Left" Text="Target" />
                            <Button
                              Classes="action"
                              Command="{CompiledBinding LoadSpellTechLiveStateCommand}"
                              Content="Load Current"
                              DockPanel.Dock="Right"
                              IsEnabled="{CompiledBinding CanLoadSpellTechLiveState}"
                            />
                          </DockPanel>
                          <Grid ColumnDefinitions="1.05*,Auto,0.75*" ColumnSpacing="8">
                            <TextBox
                              PlaceholderText="Target handle or player"
                              Text="{CompiledBinding SpellTechTargetHandleText, Mode=TwoWay}"
                            />
                            <Button
                              Grid.Column="1"
                              Classes="secondary"
                              Command="{CompiledBinding UseSelectedMobileForSpellTechTargetCommand}"
                              Content="Use Roster"
                              IsEnabled="{CompiledBinding CanUseSelectedMobileRosterHandle}"
                            />
                            <TextBox
                              Grid.Column="2"
                              PlaceholderText="Timeout ms"
                              Text="{CompiledBinding SpellTechTimeoutText, Mode=TwoWay}"
                            />
                          </Grid>
                          <TextBlock Classes="meta" Text="{CompiledBinding GameDataCatalogPresetSourceText}" />
                          <TextBlock
                            Classes="meta"
                            Text="{CompiledBinding GameDataCatalogPresetSummaryText}"
                            TextWrapping="Wrap"
                          />
                        </StackPanel>
                      </Border>

                      <Border Grid.Row="1" Classes="metric">
                        <StackPanel Spacing="12">
                          <TextBlock Classes="h2" Text="Spellbook and Schematics" />
                          <TextBlock Classes="meta" Text="{CompiledBinding SpellTechMutationStatusText}" />

                          <StackPanel Spacing="8">
                            <DockPanel LastChildFill="False">
                              <TextBlock Classes="h3" DockPanel.Dock="Left" Text="Learn Spell" />
                              <Button
                                Classes="action"
                                Command="{CompiledBinding AddSpellCommand}"
                                Content="Add Spell"
                                DockPanel.Dock="Right"
                                IsEnabled="{CompiledBinding CanAddSpell}"
                              />
                            </DockPanel>
                            <TextBox
                              PlaceholderText="Filter supported spells"
                              Text="{CompiledBinding SpellTechSpellFilterText, Mode=TwoWay}"
                            />
                            <ListBox
                              Classes="sidebar"
                              ItemsSource="{CompiledBinding SpellTechSpellEntries}"
                              MaxHeight="240"
                              SelectedItem="{CompiledBinding SelectedSpellTechSpellEntry, Mode=TwoWay}"
                            >
                              <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:GameDataQuickPickEntry">
                                  <Border
                                    Margin="0,0,0,6"
                                    Background="#11161D"
                                    BorderBrush="{DynamicResource SoftLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8,6"
                                  >
                                    <StackPanel Spacing="3">
                                      <DockPanel LastChildFill="False">
                                        <TextBlock
                                          Classes="h3"
                                          DockPanel.Dock="Left"
                                          Text="{CompiledBinding TitleText}"
                                        />
                                        <Border
                                          Background="#21262D"
                                          CornerRadius="999"
                                          DockPanel.Dock="Right"
                                          Padding="8,2"
                                        >
                                          <TextBlock Classes="meta" Text="{CompiledBinding BadgeText}" />
                                        </Border>
                                      </DockPanel>
                                      <TextBlock
                                        Classes="meta"
                                        Text="{CompiledBinding SubtitleText}"
                                        TextWrapping="Wrap"
                                      />
                                      <TextBlock Classes="code" Text="{CompiledBinding ApplyValueText}" />
                                    </StackPanel>
                                  </Border>
                                </DataTemplate>
                              </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock
                              Classes="meta"
                              Text="Spell add uses the native spellbook path with forced prerequisites, so learning a higher-tier spell also fills the lower tiers in that college."
                              TextWrapping="Wrap"
                            />
                          </StackPanel>

                          <StackPanel Spacing="8">
                            <DockPanel LastChildFill="False">
                              <TextBlock Classes="h3" DockPanel.Dock="Left" Text="Grant or Remove Schematic" />
                              <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
                                <Button
                                  Classes="action"
                                  Command="{CompiledBinding GrantSchematicCommand}"
                                  Content="Grant"
                                  IsEnabled="{CompiledBinding CanGrantSchematic}"
                                />
                                <Button
                                  Classes="secondary"
                                  Command="{CompiledBinding RemoveSchematicCommand}"
                                  Content="Remove"
                                  IsEnabled="{CompiledBinding CanRemoveSchematic}"
                                />
                              </StackPanel>
                            </DockPanel>
                            <TextBox
                              PlaceholderText="Filter supported schematics from the loaded module"
                              Text="{CompiledBinding SpellTechSchematicFilterText, Mode=TwoWay}"
                            />
                            <ListBox
                              Classes="sidebar"
                              ItemsSource="{CompiledBinding SpellTechSchematicCatalogEntries}"
                              MaxHeight="260"
                              SelectedItem="{CompiledBinding SelectedSpellTechSchematicCatalogEntry, Mode=TwoWay}"
                            >
                              <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:GameDataQuickPickEntry">
                                  <Border
                                    Margin="0,0,0,6"
                                    Background="#11161D"
                                    BorderBrush="{DynamicResource SoftLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8,6"
                                  >
                                    <StackPanel Spacing="3">
                                      <DockPanel LastChildFill="False">
                                        <TextBlock
                                          Classes="h3"
                                          DockPanel.Dock="Left"
                                          Text="{CompiledBinding TitleText}"
                                        />
                                        <Border
                                          Background="#21262D"
                                          CornerRadius="999"
                                          DockPanel.Dock="Right"
                                          Padding="8,2"
                                        >
                                          <TextBlock Classes="meta" Text="{CompiledBinding BadgeText}" />
                                        </Border>
                                      </DockPanel>
                                      <TextBlock
                                        Classes="meta"
                                        Text="{CompiledBinding SubtitleText}"
                                        TextWrapping="Wrap"
                                      />
                                      <TextBlock Classes="code" Text="{CompiledBinding ApplyValueText}" />
                                    </StackPanel>
                                  </Border>
                                </DataTemplate>
                              </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock
                              Classes="meta"
                              Text="Supported schematics come from the loaded module catalog. Grant appends one discovered schematic when it is missing, and Remove compacts the runtime list when the id is already known."
                              TextWrapping="Wrap"
                            />
                          </StackPanel>
                        </StackPanel>
                      </Border>

                      <Border Grid.Row="1" Grid.Column="1" Classes="metric">
                        <StackPanel Spacing="12">
                          <TextBlock Classes="h2" Text="Schools, Disciplines, Skills" />
                          <TextBlock
                            Classes="meta"
                            Text="Choose one supported college, discipline, or skill, then apply the level or point value without typing raw tokens."
                            TextWrapping="Wrap"
                          />

                          <StackPanel Spacing="8">
                            <TextBlock Classes="h3" Text="Spell College Rank" />
                            <Grid ColumnDefinitions="1.1*,0.65*,Auto" ColumnSpacing="8">
                              <ComboBox
                                ItemsSource="{CompiledBinding SpellTechCollegeEntries}"
                                SelectedItem="{CompiledBinding SelectedSpellTechCollegeEntry, Mode=TwoWay}"
                              >
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="viewmodels:GameDataQuickPickEntry">
                                    <TextBlock Text="{CompiledBinding TitleText}" />
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                              <ComboBox
                                Grid.Column="1"
                                ItemsSource="{CompiledBinding SpellTechCollegeLevelOptions}"
                                SelectedItem="{CompiledBinding SelectedSpellTechCollegeLevelOption, Mode=TwoWay}"
                              >
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="viewmodels:DebuggerChoiceOption">
                                    <TextBlock Text="{CompiledBinding Label}" />
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                              <Button
                                Grid.Column="2"
                                Classes="secondary"
                                Command="{CompiledBinding SetSpellCollegeLevelCommand}"
                                Content="Set"
                                IsEnabled="{CompiledBinding CanSetSpellCollegeLevel}"
                              />
                            </Grid>
                          </StackPanel>

                          <StackPanel Spacing="8">
                            <TextBlock Classes="h3" Text="Tech Discipline Degree" />
                            <Grid ColumnDefinitions="1.1*,0.65*,Auto" ColumnSpacing="8">
                              <ComboBox
                                ItemsSource="{CompiledBinding SpellTechDisciplineEntries}"
                                SelectedItem="{CompiledBinding SelectedSpellTechDisciplineEntry, Mode=TwoWay}"
                              >
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="viewmodels:GameDataQuickPickEntry">
                                    <TextBlock Text="{CompiledBinding TitleText}" />
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                              <ComboBox
                                Grid.Column="1"
                                ItemsSource="{CompiledBinding SpellTechDisciplineLevelOptions}"
                                SelectedItem="{CompiledBinding SelectedSpellTechDisciplineLevelOption, Mode=TwoWay}"
                              >
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="viewmodels:DebuggerChoiceOption">
                                    <TextBlock Text="{CompiledBinding Label}" />
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                              <Button
                                Grid.Column="2"
                                Classes="secondary"
                                Command="{CompiledBinding SetTechDisciplineLevelCommand}"
                                Content="Set"
                                IsEnabled="{CompiledBinding CanSetTechDisciplineLevel}"
                              />
                            </Grid>
                          </StackPanel>

                          <StackPanel Spacing="8">
                            <TextBlock Classes="h3" Text="Tech Skill Points" />
                            <Grid ColumnDefinitions="1.1*,0.65*,Auto" ColumnSpacing="8">
                              <ComboBox
                                ItemsSource="{CompiledBinding SpellTechSkillEntries}"
                                SelectedItem="{CompiledBinding SelectedSpellTechSkillEntry, Mode=TwoWay}"
                              >
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="viewmodels:GameDataQuickPickEntry">
                                    <TextBlock Text="{CompiledBinding TitleText}" />
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                              <ComboBox
                                Grid.Column="1"
                                ItemsSource="{CompiledBinding SpellTechSkillPointOptions}"
                                SelectedItem="{CompiledBinding SelectedSpellTechSkillPointOption, Mode=TwoWay}"
                              >
                                <ComboBox.ItemTemplate>
                                  <DataTemplate x:DataType="viewmodels:DebuggerChoiceOption">
                                    <TextBlock Text="{CompiledBinding Label}" />
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                              <Button
                                Grid.Column="2"
                                Classes="secondary"
                                Command="{CompiledBinding SetTechSkillPointsCommand}"
                                Content="Set"
                                IsEnabled="{CompiledBinding CanSetTechSkillPoints}"
                              />
                            </Grid>
                          </StackPanel>

                          <ItemsControl ItemsSource="{CompiledBinding SpellTechMutationResultLines}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <TextBlock Classes="meta" Text="{Binding}" TextWrapping="Wrap" />
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>

                          <Border
                            Background="#151A20"
                            BorderBrush="{DynamicResource SoftLineBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="8,6"
                          >
                            <StackPanel Spacing="4">
                              <TextBlock Classes="h3" Text="Result" />
                              <TextBlock
                                Classes="meta"
                                Text="{CompiledBinding SpellTechMutationDispatcherText}"
                                TextWrapping="Wrap"
                              />
                              <TextBlock
                                Classes="meta"
                                Text="{CompiledBinding SpellTechMutationExecutionDetailText}"
                                TextWrapping="Wrap"
                              />
                              <TextBlock Classes="code" Text="{CompiledBinding SpellTechMutationResultText}" />
                            </StackPanel>
                          </Border>
                        </StackPanel>
                      </Border>

                      <Border Grid.Row="2" Grid.ColumnSpan="2" Classes="metric">
                        <StackPanel Spacing="8">
                          <TextBlock Classes="h2" Text="Current Target Snapshot" />
                          <TextBlock Classes="meta" Text="{CompiledBinding SpellTechLiveStateStatusText}" />
                          <TextBlock
                            Classes="meta"
                            Text="{CompiledBinding SpellTechLiveStateSummaryText}"
                            TextWrapping="Wrap"
                          />
                          <Grid ColumnDefinitions="1*,1*,1*" ColumnSpacing="16">
                            <StackPanel Spacing="8">
                              <TextBlock Classes="h3" Text="Known Spells" />
                              <ScrollViewer MaxHeight="320" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{CompiledBinding SpellTechKnownSpellEntries}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:DebuggerSpellTechKnownSpellEntry">
                                      <Border
                                        Margin="0,0,0,6"
                                        Background="#11161D"
                                        BorderBrush="{DynamicResource SoftLineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8,6"
                                      >
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                          <StackPanel Spacing="3">
                                            <TextBlock Classes="h3" Text="{CompiledBinding TitleText}" />
                                            <TextBlock
                                              Classes="meta"
                                              Text="{CompiledBinding SubtitleText}"
                                              TextWrapping="Wrap"
                                            />
                                            <TextBlock Classes="code" Text="{CompiledBinding TokenText}" />
                                          </StackPanel>
                                          <Button
                                            Grid.Column="1"
                                            Classes="secondary"
                                            Command="{Binding #RootWindow.DataContext.UseSpellTechKnownSpellCommand}"
                                            CommandParameter="{Binding}"
                                            Content="Use"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                          />
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </ScrollViewer>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="8">
                              <TextBlock Classes="h3" Text="Live Progression" />
                              <ScrollViewer MaxHeight="320" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{CompiledBinding SpellTechProgressEntries}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:DebuggerSpellTechLiveEntry">
                                      <Border
                                        Margin="0,0,0,6"
                                        Background="#11161D"
                                        BorderBrush="{DynamicResource SoftLineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8,6"
                                      >
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                          <StackPanel Spacing="3">
                                            <DockPanel LastChildFill="False">
                                              <TextBlock
                                                Classes="h3"
                                                DockPanel.Dock="Left"
                                                Text="{CompiledBinding TitleText}"
                                              />
                                              <TextBlock
                                                Classes="code"
                                                DockPanel.Dock="Right"
                                                HorizontalAlignment="Right"
                                                Text="{CompiledBinding ValueText}"
                                              />
                                            </DockPanel>
                                            <TextBlock Classes="meta" Text="{CompiledBinding CategoryText}" />
                                            <TextBlock
                                              Classes="meta"
                                              Text="{CompiledBinding DetailText}"
                                              TextWrapping="Wrap"
                                            />
                                          </StackPanel>
                                          <Button
                                            Grid.Column="1"
                                            Classes="secondary"
                                            Command="{Binding #RootWindow.DataContext.UseSpellTechLiveEntryCommand}"
                                            CommandParameter="{Binding}"
                                            Content="Use"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                          />
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </ScrollViewer>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Spacing="8">
                              <TextBlock Classes="h3" Text="Known Schematics" />
                              <ScrollViewer MaxHeight="320" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{CompiledBinding SpellTechSchematicEntries}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:DebuggerSpellTechSchematicEntry">
                                      <Border
                                        Margin="0,0,0,6"
                                        Background="#11161D"
                                        BorderBrush="{DynamicResource SoftLineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8,6"
                                      >
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                          <StackPanel Spacing="3">
                                            <TextBlock Classes="h3" Text="{CompiledBinding TitleText}" />
                                            <TextBlock
                                              Classes="meta"
                                              Text="{CompiledBinding SubtitleText}"
                                              TextWrapping="Wrap"
                                            />
                                            <TextBlock Classes="code" Text="{CompiledBinding ValueText}" />
                                          </StackPanel>
                                          <Button
                                            Grid.Column="1"
                                            Classes="secondary"
                                            Command="{Binding #RootWindow.DataContext.UseSpellTechSchematicCommand}"
                                            CommandParameter="{Binding}"
                                            Content="Use Id"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                          />
                                        </Grid>
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </ScrollViewer>
                            </StackPanel>
                          </Grid>
                        </StackPanel>
                      </Border>
                    </Grid>
                  </TabItem>

                  <TabItem Header="Runtime">
                    <Grid Margin="0,12,0,0" ColumnDefinitions="0.9*,1.1*" ColumnSpacing="16">
                      <Border Classes="metric">
                        <StackPanel Spacing="8">
                          <TextBlock Classes="h2" Text="Writes" />
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox
                              Width="220"
                              PlaceholderText="Action points value"
                              Text="{CompiledBinding RuntimeActionPointsText, Mode=TwoWay}"
                            />
                            <Button
                              Classes="action"
                              Command="{CompiledBinding WriteRuntimeActionPointsCommand}"
                              Content="Write AP"
                            />
                          </StackPanel>
                          <TextBlock Classes="h3" Text="{CompiledBinding RuntimeStatusText}" />
                          <ItemsControl ItemsSource="{CompiledBinding RuntimeStatusResultLines}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <TextBlock Classes="meta" Text="{Binding}" TextWrapping="Wrap" />
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </Border>

                      <Border Grid.Column="1" Classes="metric">
                        <StackPanel Spacing="8">
                          <TextBlock Classes="h2" Text="Crash Dumps" />
                          <TextBox
                            PlaceholderText="Manual dump path"
                            Text="{CompiledBinding RuntimeDumpPathText, Mode=TwoWay}"
                          />
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox
                              Width="220"
                              PlaceholderText="Dump kind (mini/full)"
                              Text="{CompiledBinding RuntimeDumpKindText, Mode=TwoWay}"
                            />
                            <Button
                              Classes="action"
                              Command="{CompiledBinding WriteRuntimeCrashDumpCommand}"
                              Content="Write Dump"
                            />
                          </StackPanel>
                          <TextBox
                            PlaceholderText="Process exe (Arcanum.exe)"
                            Text="{CompiledBinding RuntimeDumpProcessNameText, Mode=TwoWay}"
                          />
                          <TextBox
                            PlaceholderText="Automatic dump directory"
                            Text="{CompiledBinding RuntimeDumpDirectoryText, Mode=TwoWay}"
                          />
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox
                              Width="120"
                              PlaceholderText="Dump count"
                              Text="{CompiledBinding RuntimeDumpCountText, Mode=TwoWay}"
                            />
                            <Button
                              Classes="secondary"
                              Command="{CompiledBinding InspectAutomaticCrashDumpsCommand}"
                              Content="Inspect Auto"
                            />
                            <Button
                              Classes="secondary"
                              Command="{CompiledBinding EnableAutomaticCrashDumpsCommand}"
                              Content="Enable Auto"
                            />
                            <Button
                              Classes="secondary"
                              Command="{CompiledBinding DisableAutomaticCrashDumpsCommand}"
                              Content="Disable Auto"
                            />
                          </StackPanel>
                          <TextBlock Classes="h3" Text="{CompiledBinding RuntimeDumpStatusText}" />
                          <ItemsControl ItemsSource="{CompiledBinding RuntimeDumpResultLines}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <TextBlock Classes="meta" Text="{Binding}" TextWrapping="Wrap" />
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </Border>
                    </Grid>
                  </TabItem>

                  <TabItem Header="Catalogs">
                    <StackPanel Margin="0,12,0,0" Spacing="12">
                      <Border Classes="metric">
                        <StackPanel Spacing="8">
                          <DockPanel LastChildFill="False">
                            <TextBlock Classes="h2" DockPanel.Dock="Left" Text="Local Game-Data Catalog" />
                            <Button
                              Classes="action"
                              Command="{CompiledBinding LoadGameDataCatalogCommand}"
                              Content="Reload Module Catalog"
                              DockPanel.Dock="Right"
                              IsEnabled="{CompiledBinding CanLoadGameDataCatalog}"
                            />
                          </DockPanel>
                          <TextBlock Classes="meta" Text="{CompiledBinding GameDataCatalogPresetSourceText}" />
                          <TextBlock
                            Classes="meta"
                            Text="{CompiledBinding GameDataCatalogPresetSummaryText}"
                            TextWrapping="Wrap"
                          />
                          <TextBlock Classes="meta" Text="{CompiledBinding GameDataCatalogStatusText}" />
                          <TextBlock
                            Classes="meta"
                            Text="{CompiledBinding GameDataCatalogSummaryText}"
                            TextWrapping="Wrap"
                          />
                          <TextBlock Classes="h3" Text="Staged Supported Input" />
                          <TextBox IsReadOnly="True" Text="{CompiledBinding GameDataCatalogStagedInputText}" />
                          <TextBlock
                            Classes="meta"
                            Text="{CompiledBinding GameDataCatalogStagedInputSummaryText}"
                            TextWrapping="Wrap"
                          />
                        </StackPanel>
                      </Border>

                      <TabControl SelectedIndex="{CompiledBinding SelectedGameDataCatalogTabIndex, Mode=TwoWay}">
                        <TabItem Header="Prototypes">
                          <Border Classes="metric" Margin="0,12,0,0">
                            <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="8">
                              <TextBlock Classes="h2" Text="Prototype Browser" />

                              <StackPanel Grid.Row="1" Spacing="8">
                                <Grid ColumnDefinitions="1.15*,0.85*" ColumnSpacing="8">
                                  <TextBox
                                    PlaceholderText="Filter by name, proto, type, asset path, or art"
                                    Text="{CompiledBinding GameDataCatalogPrototypeFilterText, Mode=TwoWay}"
                                  />
                                  <ComboBox
                                    Grid.Column="1"
                                    ItemsSource="{CompiledBinding GameDataCatalogPrototypeScopeOptions}"
                                    SelectedItem="{CompiledBinding SelectedGameDataCatalogPrototypeScopeOption, Mode=TwoWay}"
                                  >
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate x:DataType="viewmodels:DebuggerChoiceOption">
                                        <TextBlock Text="{CompiledBinding Label}" />
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                </Grid>
                                <TextBlock
                                  Classes="meta"
                                  Text="{CompiledBinding GameDataCatalogPrototypeScopeDescriptionText}"
                                  TextWrapping="Wrap"
                                />
                              </StackPanel>

                              <ListBox
                                Grid.Row="2"
                                Classes="sidebar"
                                ItemsSource="{CompiledBinding GameDataCatalogPrototypeEntries}"
                                SelectedItem="{CompiledBinding SelectedGameDataCatalogPrototypeEntry, Mode=TwoWay}"
                              >
                                <ListBox.ItemTemplate>
                                  <DataTemplate x:DataType="workspace:PrototypePaletteEntry">
                                    <Border
                                      Margin="0,0,0,6"
                                      Background="#151A20"
                                      BorderBrush="{DynamicResource SoftLineBrush}"
                                      BorderThickness="1"
                                      CornerRadius="6"
                                      Padding="8,6"
                                    >
                                      <StackPanel Spacing="3">
                                        <DockPanel LastChildFill="False">
                                          <TextBlock
                                            Classes="h3"
                                            DockPanel.Dock="Left"
                                            Text="{CompiledBinding DisplayName}"
                                          />
                                          <Border
                                            Background="#21262D"
                                            CornerRadius="999"
                                            DockPanel.Dock="Right"
                                            Padding="8,3"
                                          >
                                            <TextBlock Classes="meta" Text="{CompiledBinding ObjectType}" />
                                          </Border>
                                        </DockPanel>
                                        <TextBlock Classes="meta" Text="{CompiledBinding AssetPath}" />
                                        <TextBlock Classes="meta" Text="{CompiledBinding Description}" />
                                        <DockPanel LastChildFill="False">
                                          <TextBlock
                                            Classes="code"
                                            DockPanel.Dock="Left"
                                            Text="{CompiledBinding ProtoNumber}"
                                          />
                                          <TextBlock
                                            Classes="meta"
                                            DockPanel.Dock="Right"
                                            Text="{CompiledBinding PaletteGroup}"
                                          />
                                        </DockPanel>
                                      </StackPanel>
                                    </Border>
                                  </DataTemplate>
                                </ListBox.ItemTemplate>
                              </ListBox>

                              <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
                                <Button
                                  Classes="secondary"
                                  Command="{CompiledBinding UseSelectedCatalogPrototypeForLookupCommand}"
                                  Content="Use for Lookup"
                                  IsEnabled="{CompiledBinding CanUseSelectedCatalogPrototypeForLookup}"
                                />
                                <Button
                                  Classes="secondary"
                                  Command="{CompiledBinding UseSelectedCatalogPrototypeForInventoryCommand}"
                                  Content="Use for Inventory"
                                  IsEnabled="{CompiledBinding CanUseSelectedCatalogPrototypeForInventory}"
                                />
                                <Button
                                  Classes="action"
                                  Command="{CompiledBinding UseSelectedCatalogPrototypeForSpawnCommand}"
                                  Content="Use for Spawn"
                                  IsEnabled="{CompiledBinding CanUseSelectedCatalogPrototypeForSpawn}"
                                />
                              </StackPanel>
                            </Grid>
                          </Border>
                        </TabItem>

                        <TabItem Header="World Map">
                          <Border Classes="metric" Margin="0,12,0,0">
                            <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="8">
                              <TextBlock Classes="h2" Text="World Map Locations" />

                              <StackPanel Grid.Row="1" Spacing="8">
                                <TextBox
                                  PlaceholderText="Filter by area, name, description, or linked map"
                                  Text="{CompiledBinding GameDataCatalogWorldFilterText, Mode=TwoWay}"
                                />
                                <TextBlock
                                  Classes="meta"
                                  Text="Apply one location to the guided teleport fields. These coordinates target the global world scene, so use them when the traveler is already on the world map."
                                  TextWrapping="Wrap"
                                />
                              </StackPanel>

                              <ListBox
                                Grid.Row="2"
                                Classes="sidebar"
                                ItemsSource="{CompiledBinding GameDataCatalogWorldEntries}"
                                SelectedItem="{CompiledBinding SelectedGameDataCatalogWorldEntry, Mode=TwoWay}"
                              >
                                <ListBox.ItemTemplate>
                                  <DataTemplate x:DataType="workspace:WorldMapCatalogEntry">
                                    <Border
                                      Margin="0,0,0,6"
                                      Background="#151A20"
                                      BorderBrush="{DynamicResource SoftLineBrush}"
                                      BorderThickness="1"
                                      CornerRadius="6"
                                      Padding="8,6"
                                    >
                                      <StackPanel Spacing="3">
                                        <DockPanel LastChildFill="False">
                                          <TextBlock
                                            Classes="h3"
                                            DockPanel.Dock="Left"
                                            Text="{CompiledBinding DisplayName}"
                                          />
                                          <Border
                                            Background="#21262D"
                                            CornerRadius="999"
                                            DockPanel.Dock="Right"
                                            Padding="8,3"
                                          >
                                            <TextBlock Classes="meta" Text="{CompiledBinding AreaId}" />
                                          </Border>
                                        </DockPanel>
                                        <TextBlock Classes="meta" Text="{CompiledBinding CoordinateText}" />
                                        <TextBlock Classes="meta" Text="{CompiledBinding MapSummaryText}" />
                                        <TextBlock Classes="meta" Text="{CompiledBinding Description}" />
                                      </StackPanel>
                                    </Border>
                                  </DataTemplate>
                                </ListBox.ItemTemplate>
                              </ListBox>

                              <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
                                <Button
                                  Classes="action"
                                  Command="{CompiledBinding UseSelectedCatalogWorldLocationForGuidedActionCommand}"
                                  Content="Use for Teleport"
                                  IsEnabled="{CompiledBinding CanUseSelectedCatalogWorldLocationForGuidedAction}"
                                />
                              </StackPanel>
                            </Grid>
                          </Border>
                        </TabItem>

                        <TabItem Header="Tile Art">
                          <Border Classes="metric" Margin="0,12,0,0">
                            <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="8">
                              <TextBlock Classes="h2" Text="Tile Art Ids" />

                              <StackPanel Grid.Row="1" Spacing="8">
                                <TextBox
                                  PlaceholderText="Filter by art id, name, type, path, or summary"
                                  Text="{CompiledBinding GameDataCatalogTileArtFilterText, Mode=TwoWay}"
                                />
                                <TextBlock
                                  Classes="meta"
                                  Text="Browse the local tile-art palette to resolve canonical AIDs from the installed game data instead of decoding raw bitfields by hand."
                                  TextWrapping="Wrap"
                                />
                              </StackPanel>

                              <ListBox
                                Grid.Row="2"
                                Classes="sidebar"
                                ItemsSource="{CompiledBinding GameDataCatalogTileArtEntries}"
                                SelectedItem="{CompiledBinding SelectedGameDataCatalogTileArtEntry, Mode=TwoWay}"
                              >
                                <ListBox.ItemTemplate>
                                  <DataTemplate x:DataType="workspace:TileArtCatalogEntry">
                                    <Border
                                      Margin="0,0,0,6"
                                      Background="#151A20"
                                      BorderBrush="{DynamicResource SoftLineBrush}"
                                      BorderThickness="1"
                                      CornerRadius="6"
                                      Padding="8,6"
                                    >
                                      <StackPanel Spacing="3">
                                        <DockPanel LastChildFill="False">
                                          <TextBlock
                                            Classes="h3"
                                            DockPanel.Dock="Left"
                                            Text="{CompiledBinding DisplayName}"
                                          />
                                          <Border
                                            Background="#21262D"
                                            CornerRadius="999"
                                            DockPanel.Dock="Right"
                                            Padding="8,3"
                                          >
                                            <TextBlock Classes="meta" Text="{CompiledBinding ArtTypeText}" />
                                          </Border>
                                        </DockPanel>
                                        <TextBlock Classes="meta" Text="{CompiledBinding SummaryText}" />
                                        <TextBlock Classes="meta" Text="{CompiledBinding AssetPath}" />
                                        <TextBlock Classes="code" Text="{CompiledBinding ArtIdText}" />
                                      </StackPanel>
                                    </Border>
                                  </DataTemplate>
                                </ListBox.ItemTemplate>
                              </ListBox>

                              <controls:GameDataValueOptionPanel
                                Grid.Row="3"
                                ApplyEntryCommand="{CompiledBinding StageSelectedGameDataCatalogInputCommand}"
                                ApplyValueCommand="{CompiledBinding StageSelectedGameDataCatalogInputValueCommand}"
                                EmptyStateText="Select one tile-art row to stage its canonical art id here."
                                Entry="{CompiledBinding SelectedGameDataCatalogTileArtValueEntry}"
                                TitleText="Supported Tile-Art Input"
                              />
                            </Grid>
                          </Border>
                        </TabItem>

                        <TabItem Header="Static Objects">
                          <Border Classes="metric" Margin="0,12,0,0">
                            <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="8">
                              <TextBlock Classes="h2" Text="Static Object Ids" />

                              <StackPanel Grid.Row="1" Spacing="8">
                                <TextBox
                                  PlaceholderText="Filter by name, type, proto, object id, guid, asset path, or tile"
                                  Text="{CompiledBinding GameDataCatalogStaticObjectFilterText, Mode=TwoWay}"
                                />
                                <TextBlock
                                  Classes="meta"
                                  Text="Browse loaded mob and sector assets to inspect placed object ids, GUIDs, prototypes, and source paths. Use the token actions when you want lookup, inventory creation, or live spawning to reuse one exact workspace-backed object reference instead of guessing its proto."
                                  TextWrapping="Wrap"
                                />
                              </StackPanel>

                              <ListBox
                                Grid.Row="2"
                                Classes="sidebar"
                                ItemsSource="{CompiledBinding GameDataCatalogStaticObjectEntries}"
                                SelectedItem="{CompiledBinding SelectedGameDataCatalogStaticObjectEntry, Mode=TwoWay}"
                              >
                                <ListBox.ItemTemplate>
                                  <DataTemplate x:DataType="workspace:StaticObjectCatalogEntry">
                                    <Border
                                      Margin="0,0,0,6"
                                      Background="#151A20"
                                      BorderBrush="{DynamicResource SoftLineBrush}"
                                      BorderThickness="1"
                                      CornerRadius="6"
                                      Padding="8,6"
                                    >
                                      <StackPanel Spacing="3">
                                        <DockPanel LastChildFill="False">
                                          <TextBlock
                                            Classes="h3"
                                            DockPanel.Dock="Left"
                                            Text="{CompiledBinding DisplayName}"
                                          />
                                          <Border
                                            Background="#21262D"
                                            CornerRadius="999"
                                            DockPanel.Dock="Right"
                                            Padding="8,3"
                                          >
                                            <TextBlock Classes="meta" Text="{CompiledBinding ObjectType}" />
                                          </Border>
                                        </DockPanel>
                                        <TextBlock Classes="meta" Text="{CompiledBinding SummaryText}" />
                                        <TextBlock Classes="meta" Text="{CompiledBinding PrototypeText}" />
                                        <TextBlock Classes="meta" Text="{CompiledBinding LocationText}" />
                                        <TextBlock Classes="code" Text="{CompiledBinding ObjectIdText}" />
                                      </StackPanel>
                                    </Border>
                                  </DataTemplate>
                                </ListBox.ItemTemplate>
                              </ListBox>

                              <StackPanel Grid.Row="3" Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                  <Button
                                    Classes="secondary"
                                    Command="{CompiledBinding UseSelectedCatalogStaticObjectPrototypeForLookupCommand}"
                                    Content="Use Token for Lookup"
                                    IsEnabled="{CompiledBinding CanUseSelectedCatalogStaticObjectPrototypeForLookup}"
                                  />
                                  <Button
                                    Classes="secondary"
                                    Command="{CompiledBinding UseSelectedCatalogStaticObjectPrototypeForInventoryCommand}"
                                    Content="Use Token for Inventory"
                                    IsEnabled="{CompiledBinding CanUseSelectedCatalogStaticObjectPrototypeForInventory}"
                                  />
                                  <Button
                                    Classes="action"
                                    Command="{CompiledBinding UseSelectedCatalogStaticObjectPrototypeForSpawnCommand}"
                                    Content="Use Token for Spawn"
                                    IsEnabled="{CompiledBinding CanUseSelectedCatalogStaticObjectPrototypeForSpawn}"
                                  />
                                </StackPanel>
                                <controls:GameDataValueOptionPanel
                                  ApplyEntryCommand="{CompiledBinding StageSelectedGameDataCatalogInputCommand}"
                                  ApplyValueCommand="{CompiledBinding StageSelectedGameDataCatalogInputValueCommand}"
                                  EmptyStateText="Select one placed object row to stage its GUID, object id, or proto token here."
                                  Entry="{CompiledBinding SelectedGameDataCatalogStaticObjectValueEntry}"
                                  TitleText="Supported Object Inputs"
                                />
                                <TextBlock Classes="h3" Text="Selected Object" />
                                <TextBox
                                  IsReadOnly="True"
                                  Text="{CompiledBinding GameDataCatalogSelectedStaticObjectIdText}"
                                />
                                <TextBox
                                  IsReadOnly="True"
                                  Text="{CompiledBinding GameDataCatalogSelectedStaticObjectGuidText}"
                                />
                                <TextBlock
                                  Classes="meta"
                                  Text="{CompiledBinding GameDataCatalogSelectedStaticObjectSummaryText}"
                                  TextWrapping="Wrap"
                                />
                              </StackPanel>
                            </Grid>
                          </Border>
                        </TabItem>
                      </TabControl>
                    </StackPanel>
                  </TabItem>

                  <TabItem Header="Native Calls">
                    <Grid Margin="0,12,0,0" ColumnDefinitions="1.1*,0.9*" ColumnSpacing="16">
                      <Border Classes="metric">
                        <StackPanel Spacing="8">
                          <TextBlock Classes="h2" Text="Native Call" />
                          <TextBlock Classes="meta" Text="{CompiledBinding FunctionCallStatusText}" />
                          <ComboBox
                            ItemsSource="{CompiledBinding FunctionCallOptions}"
                            SelectedItem="{CompiledBinding SelectedFunctionCallOption, Mode=TwoWay}"
                          >
                            <ComboBox.ItemTemplate>
                              <DataTemplate x:DataType="diag:FunctionDefinition">
                                <TextBlock Text="{CompiledBinding Key}" />
                              </DataTemplate>
                            </ComboBox.ItemTemplate>
                          </ComboBox>
                          <TextBox
                            PlaceholderText="ui_start_dialog or 0x000609E0"
                            Text="{CompiledBinding FunctionCallTargetText, Mode=TwoWay}"
                          />
                          <TextBlock
                            Classes="meta"
                            Text="{CompiledBinding FunctionCallTargetSummaryText}"
                            TextWrapping="Wrap"
                          />
                          <TextBlock
                            Classes="meta"
                            Text="{CompiledBinding FunctionCallExampleText}"
                            TextWrapping="Wrap"
                          />
                          <TextBox
                            AcceptsReturn="True"
                            MinHeight="72"
                            PlaceholderText="handle(player), 0x20, -1"
                            Text="{CompiledBinding FunctionCallStackArgumentsText, Mode=TwoWay}"
                            TextWrapping="Wrap"
                          />
                          <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <TextBox
                              PlaceholderText="ECX or handle_low(player)"
                              Text="{CompiledBinding FunctionCallEcxText, Mode=TwoWay}"
                            />
                            <TextBox
                              Grid.Column="1"
                              PlaceholderText="EDX or handle_high(player)"
                              Text="{CompiledBinding FunctionCallEdxText, Mode=TwoWay}"
                            />
                            <TextBox
                              Grid.Column="2"
                              PlaceholderText="Timeout ms"
                              Text="{CompiledBinding FunctionCallTimeoutText, Mode=TwoWay}"
                            />
                          </Grid>
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <CheckBox
                              Content="Use cleanup"
                              IsChecked="{CompiledBinding FunctionCallUseSuggestedCleanup, Mode=TwoWay}"
                            />
                            <ComboBox
                              Width="140"
                              ItemsSource="{CompiledBinding FunctionCallCleanupOptions}"
                              SelectedItem="{CompiledBinding SelectedFunctionCallCleanupOption, Mode=TwoWay}"
                            >
                              <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:DebuggerCleanupModeOption">
                                  <TextBlock Text="{CompiledBinding Label}" />
                                </DataTemplate>
                              </ComboBox.ItemTemplate>
                            </ComboBox>
                          </StackPanel>
                          <Button
                            Classes="action"
                            Command="{CompiledBinding InvokeFunctionCallCommand}"
                            Content="Invoke"
                            IsEnabled="{CompiledBinding CanInvokeFunctionCall}"
                          />
                          <Border
                            Background="#151A20"
                            BorderBrush="{DynamicResource SoftLineBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="8,6"
                          >
                            <StackPanel Spacing="4">
                              <TextBlock Classes="h3" Text="Result" />
                              <TextBlock
                                Classes="meta"
                                Text="{CompiledBinding FunctionCallDispatcherText}"
                                TextWrapping="Wrap"
                              />
                              <TextBlock
                                Classes="meta"
                                Text="{CompiledBinding FunctionCallExecutionDetailText}"
                                TextWrapping="Wrap"
                              />
                              <TextBlock Classes="code" Text="{CompiledBinding FunctionCallResultText}" />
                            </StackPanel>
                          </Border>
                          <ItemsControl ItemsSource="{CompiledBinding FunctionCallArguments}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate x:DataType="core:FunctionCallArgumentSnapshot">
                                <Border
                                  Margin="0,0,0,6"
                                  Background="#151A20"
                                  BorderBrush="{DynamicResource SoftLineBrush}"
                                  BorderThickness="1"
                                  CornerRadius="6"
                                  Padding="8,6"
                                >
                                  <StackPanel Spacing="2">
                                    <TextBlock
                                      Classes="meta"
                                      FontWeight="SemiBold"
                                      Text="{CompiledBinding SourceText}"
                                    />
                                    <TextBlock Classes="code" Text="{CompiledBinding ValueText}" />
                                  </StackPanel>
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </Border>

                      <StackPanel Grid.Column="1" Spacing="16">
                        <Border Classes="metric">
                          <StackPanel Spacing="8">
                            <TextBlock Classes="h2" Text="Known Entry Points" />
                            <ItemsControl ItemsSource="{CompiledBinding FeaturedFunctions}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:DebuggerFunctionCard">
                                  <Border
                                    Margin="0,0,0,6"
                                    Background="#151A20"
                                    BorderBrush="{DynamicResource SoftLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8,6"
                                  >
                                    <StackPanel Spacing="3">
                                      <TextBlock Classes="h3" Text="{CompiledBinding Key}" />
                                      <TextBlock Classes="code" Text="{CompiledBinding Site}" />
                                    </StackPanel>
                                  </Border>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </StackPanel>
                        </Border>

                        <Border Classes="metric">
                          <StackPanel Spacing="8">
                            <TextBlock Classes="h2" Text="Dispatcher" />
                            <ItemsControl ItemsSource="{CompiledBinding DispatcherCandidates}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="diag:DispatcherCandidateDefinition">
                                  <Border
                                    Margin="0,0,0,6"
                                    Background="#151A20"
                                    BorderBrush="{DynamicResource SoftLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8,6"
                                  >
                                    <StackPanel Spacing="3">
                                      <TextBlock Classes="h3" Text="{CompiledBinding Key}" />
                                      <TextBlock Classes="code" Text="{CompiledBinding Site}" />
                                    </StackPanel>
                                  </Border>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </StackPanel>
                        </Border>
                      </StackPanel>
                    </Grid>
                  </TabItem>

                  <TabItem Header="Hooks">
                    <StackPanel Margin="0,12,0,0" Spacing="16">
                      <TabControl>
                        <TabItem Header="Audit">
                          <Border Classes="metric" Margin="0,0,0,0">
                            <StackPanel Spacing="8">
                              <TextBlock Classes="h2" Text="Audit" />
                              <CheckBox
                                Content="Audit passes"
                                IsChecked="{CompiledBinding AuditIncludeHooks, Mode=TwoWay}"
                              />
                              <TextBox
                                PlaceholderText="Hooks: session-core|teleport_do"
                                Text="{CompiledBinding AuditHookSelectorsText, Mode=TwoWay}"
                              />
                              <Grid ColumnDefinitions="0.8*,0.8*,0.8*" ColumnSpacing="8">
                                <TextBox
                                  PlaceholderText="Hook duration ms"
                                  Text="{CompiledBinding AuditHookDurationMillisecondsText, Mode=TwoWay}"
                                />
                                <TextBox
                                  Grid.Column="1"
                                  PlaceholderText="Stack dwords"
                                  Text="{CompiledBinding AuditStackCaptureDwordCountText, Mode=TwoWay}"
                                />
                                <CheckBox
                                  Grid.Column="2"
                                  Content="Stop on failure"
                                  IsChecked="{CompiledBinding AuditStopOnFailure, Mode=TwoWay}"
                                />
                              </Grid>
                              <StackPanel Orientation="Horizontal" Spacing="8">
                                <CheckBox
                                  Content="Watch"
                                  IsChecked="{CompiledBinding AuditIncludeWatchPass, Mode=TwoWay}"
                                />
                                <CheckBox
                                  Content="Intercept"
                                  IsChecked="{CompiledBinding AuditIncludeInterceptPass, Mode=TwoWay}"
                                />
                                <Button
                                  Classes="action"
                                  Command="{CompiledBinding RunRuntimeAuditCommand}"
                                  Content="Run Audit"
                                />
                              </StackPanel>
                              <TextBlock Classes="h3" Text="{CompiledBinding AuditStatusText}" />
                              <ItemsControl ItemsSource="{CompiledBinding AuditResultLines}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <TextBlock Classes="meta" Text="{Binding}" TextWrapping="Wrap" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </Border>
                        </TabItem>

                        <TabItem Header="Interception">
                          <Border Classes="metric" Margin="0,0,0,0">
                            <StackPanel Spacing="8">
                              <TextBlock Classes="h2" Text="Interception" />
                              <Grid ColumnDefinitions="1.2*,0.45*,0.45*,0.45*,0.45*" ColumnSpacing="8">
                                <TextBox
                                  PlaceholderText="teleport_do or 0x000609E0"
                                  Text="{CompiledBinding InterceptTargetText, Mode=TwoWay}"
                                />
                                <TextBox
                                  Grid.Column="1"
                                  PlaceholderText="Stack dwords"
                                  Text="{CompiledBinding InterceptStackCaptureCountText, Mode=TwoWay}"
                                />
                                <TextBox
                                  Grid.Column="2"
                                  PlaceholderText="Cleanup bytes"
                                  Text="{CompiledBinding InterceptCleanupBytesText, Mode=TwoWay}"
                                />
                                <TextBox
                                  Grid.Column="3"
                                  PlaceholderText="Return EAX"
                                  Text="{CompiledBinding InterceptReturnEaxText, Mode=TwoWay}"
                                />
                                <TextBox
                                  Grid.Column="4"
                                  PlaceholderText="Return EDX"
                                  Text="{CompiledBinding InterceptReturnEdxText, Mode=TwoWay}"
                                />
                              </Grid>
                              <CheckBox
                                Content="Mutation only"
                                IsChecked="{CompiledBinding InterceptSkipOriginal, Mode=TwoWay}"
                              />
                              <TextBox
                                PlaceholderText="Regs: eax=0x1|ecx=42"
                                Text="{CompiledBinding InterceptRegisterOverridesText, Mode=TwoWay}"
                              />
                              <TextBox
                                PlaceholderText="Args: 0=0x123|1=42"
                                Text="{CompiledBinding InterceptArgumentOverridesText, Mode=TwoWay}"
                              />
                              <TextBox
                                PlaceholderText="Deref: eax:16|stack0:32"
                                Text="{CompiledBinding InterceptDereferencesText, Mode=TwoWay}"
                              />
                              <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button
                                  Classes="action"
                                  Command="{CompiledBinding StartRuntimeInterceptCommand}"
                                  Content="Start"
                                />
                                <Button
                                  Classes="secondary"
                                  Command="{CompiledBinding PollRuntimeInterceptCommand}"
                                  Content="Poll"
                                />
                                <Button
                                  Classes="secondary"
                                  Command="{CompiledBinding StopRuntimeInterceptCommand}"
                                  Content="Stop"
                                />
                              </StackPanel>
                              <TextBlock Classes="h3" Text="{CompiledBinding InterceptStatusText}" />
                              <ItemsControl ItemsSource="{CompiledBinding InterceptResultLines}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <TextBlock Classes="meta" Text="{Binding}" TextWrapping="Wrap" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </Border>
                        </TabItem>
                      </TabControl>
                    </StackPanel>
                  </TabItem>
                </TabControl>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <TabItem Header="Inspect">
            <Grid Margin="2,12,2,2" ColumnDefinitions="320,*" ColumnSpacing="16">
              <Border Classes="metric">
                <Grid RowDefinitions="Auto,*" RowSpacing="12">
                  <StackPanel Spacing="8">
                    <TextBlock Classes="h2" Text="Target" />
                    <TextBlock Classes="meta" Text="{CompiledBinding ObjectProbeStatusText}" />
                    <TextBlock Classes="meta" Text="{CompiledBinding ObjectProbeSummaryText}" TextWrapping="Wrap" />
                    <TextBox
                      PlaceholderText="0x000000004000004A or player"
                      Text="{CompiledBinding ObjectProbeHandleText, Mode=TwoWay}"
                    />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Button
                        Classes="secondary"
                        Command="{CompiledBinding UseSelectedEventHandleCommand}"
                        Content="Use Event"
                        IsEnabled="{CompiledBinding CanUseSelectedEventHandle}"
                      />
                      <Button
                        Classes="secondary"
                        Command="{CompiledBinding InspectActivePlayerCommand}"
                        Content="Player"
                        IsEnabled="{CompiledBinding CanInspectActivePlayer}"
                      />
                      <Button
                        Classes="action"
                        Command="{CompiledBinding InspectObjectHandleCommand}"
                        Content="Inspect Handle"
                        IsEnabled="{CompiledBinding CanInspectObjectHandle}"
                      />
                    </StackPanel>
                    <TextBlock
                      Classes="meta"
                      Text="Inspect actions launched from the Mobiles roster or timeline reuse this surface automatically, so this tab stays focused on deep detail review."
                      TextWrapping="Wrap"
                    />
                  </StackPanel>

                  <StackPanel Grid.Row="1" Spacing="8">
                    <TextBlock Classes="h3" Text="Recent" />
                    <ListBox
                      Classes="sidebar"
                      ItemsSource="{CompiledBinding ObjectProbeObjects}"
                      SelectedItem="{CompiledBinding SelectedObjectProbeObject, Mode=TwoWay}"
                    >
                      <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="core:ObjectProbeObjectSnapshot">
                          <Border
                            Margin="0,0,0,6"
                            Background="#151A20"
                            BorderBrush="{DynamicResource SoftLineBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="8,6"
                          >
                            <StackPanel Spacing="3">
                              <TextBlock Classes="h3" Text="{CompiledBinding ObjectTypeText}" />
                              <TextBlock Classes="meta" Text="{CompiledBinding StatusText}" />
                              <TextBlock Classes="code" Text="{CompiledBinding HandleHex}" />
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </StackPanel>
                </Grid>
              </Border>

              <Border Classes="metric" Grid.Column="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                  <StackPanel Spacing="8">
                    <TextBlock Classes="h2" Text="Details" />
                    <ContentControl Content="{CompiledBinding SelectedObjectProbeObject}">
                      <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="core:ObjectProbeObjectSnapshot">
                          <StackPanel Spacing="12">
                            <StackPanel Spacing="4">
                              <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Classes="h1" Text="{CompiledBinding ObjectTypeText}" />
                                <Border DockPanel.Dock="Right" Background="#21262D" CornerRadius="999" Padding="8,3">
                                  <TextBlock Classes="meta" Text="{CompiledBinding ResolutionSource}" />
                                </Border>
                              </DockPanel>
                              <TextBlock Classes="meta" Text="{CompiledBinding StatusText}" />
                              <TextBlock Classes="code" Text="{CompiledBinding HandleHex}" />
                              <TextBlock Classes="meta" Text="{CompiledBinding ObjectIdText}" />
                              <TextBlock Classes="meta" Text="{CompiledBinding PrototypeText}" />
                              <TextBlock Classes="code" Text="{CompiledBinding PrototypeHandleText}" />
                              <TextBlock Classes="code" Text="{CompiledBinding AddressText}" />
                            </StackPanel>

                            <ItemsControl ItemsSource="{CompiledBinding Sections}">
                              <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                  <WrapPanel />
                                </ItemsPanelTemplate>
                              </ItemsControl.ItemsPanel>
                              <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="core:ObjectProbeSectionSnapshot">
                                  <Border
                                    Width="265"
                                    Margin="0,0,10,10"
                                    Background="#151A20"
                                    BorderBrush="{DynamicResource SoftLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8,6"
                                  >
                                    <StackPanel Spacing="6">
                                      <TextBlock Classes="h3" Text="{CompiledBinding Title}" />
                                      <ItemsControl ItemsSource="{CompiledBinding Details}">
                                        <ItemsControl.ItemTemplate>
                                          <DataTemplate x:DataType="core:ObjectProbeDetailSnapshot">
                                            <DockPanel LastChildFill="False">
                                              <TextBlock
                                                DockPanel.Dock="Left"
                                                Classes="meta"
                                                FontWeight="SemiBold"
                                                Text="{CompiledBinding Label}"
                                              />
                                              <TextBlock
                                                DockPanel.Dock="Right"
                                                Classes="meta"
                                                Text="{CompiledBinding Value}"
                                              />
                                            </DockPanel>
                                          </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                      </ItemsControl>
                                    </StackPanel>
                                  </Border>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </StackPanel>
                        </DataTemplate>
                      </ContentControl.ContentTemplate>
                    </ContentControl>
                  </StackPanel>
                </ScrollViewer>
              </Border>
            </Grid>
          </TabItem>
        </TabControl>
      </Border>
    </Grid>
  </Grid>
</Window>
