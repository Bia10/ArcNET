<UserControl
  x:Class="ArcanumDebugger.App.Controls.GameDataSupportedInputPanel"
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:ArcanumDebugger.App.Controls"
  xmlns:viewmodels="using:ArcanumDebugger.App.ViewModels"
  x:Name="SupportedInputPanelRoot"
  x:DataType="controls:GameDataSupportedInputPanel"
>
  <Border
    Background="#11161D"
    BorderBrush="{DynamicResource SoftLineBrush}"
    BorderThickness="1"
    CornerRadius="6"
    Padding="8,6"
  >
    <StackPanel Spacing="6">
      <DockPanel LastChildFill="False">
        <TextBlock
          Classes="h3"
          DockPanel.Dock="Left"
          Text="{CompiledBinding #SupportedInputPanelRoot.State.TitleText}"
        />
        <Button
          Classes="secondary"
          Command="{CompiledBinding #SupportedInputPanelRoot.BrowseCommand}"
          Content="{CompiledBinding #SupportedInputPanelRoot.State.BrowseButtonText}"
          DockPanel.Dock="Right"
        />
      </DockPanel>
      <TextBlock
        Classes="meta"
        IsVisible="{CompiledBinding #SupportedInputPanelRoot.State.ShowSummary}"
        Text="{CompiledBinding #SupportedInputPanelRoot.State.SummaryText}"
        TextWrapping="Wrap"
      />
      <TextBlock
        Classes="meta"
        IsVisible="{CompiledBinding #SupportedInputPanelRoot.State.ShowEmptyState}"
        Text="{CompiledBinding #SupportedInputPanelRoot.State.EmptyStateText}"
        TextWrapping="Wrap"
      />
      <TextBox
        PlaceholderText="{CompiledBinding #SupportedInputPanelRoot.State.FilterPlaceholderText}"
        Text="{CompiledBinding #SupportedInputPanelRoot.FilterText, Mode=TwoWay}"
      />
      <ItemsControl
        IsVisible="{CompiledBinding #SupportedInputPanelRoot.State.HasEntries}"
        ItemsSource="{CompiledBinding #SupportedInputPanelRoot.State.Entries}"
      >
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="viewmodels:GameDataQuickPickEntry">
            <Border
              Margin="0,0,0,6"
              Background="#0F141A"
              BorderBrush="{DynamicResource SoftLineBrush}"
              BorderThickness="1"
              CornerRadius="6"
              Padding="8,6"
            >
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <StackPanel Spacing="3">
                  <DockPanel LastChildFill="True">
                    <Border Background="#21262D" CornerRadius="999" DockPanel.Dock="Left" Padding="8,2">
                      <TextBlock Classes="meta" Text="{CompiledBinding BadgeText}" />
                    </Border>
                    <TextBlock
                      Classes="meta"
                      DockPanel.Dock="Right"
                      HorizontalAlignment="Right"
                      Text="{CompiledBinding SubtitleText}"
                    />
                  </DockPanel>
                  <TextBlock Classes="h3" Text="{CompiledBinding TitleText}" />
                  <TextBlock Classes="meta" Text="{CompiledBinding DetailText}" TextWrapping="Wrap" />
                </StackPanel>
                <Button
                  Grid.Column="1"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center"
                  Classes="action"
                  Command="{CompiledBinding #SupportedInputPanelRoot.ApplyEntryCommand}"
                  CommandParameter="{Binding}"
                  Content="Use"
                />
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </Border>
</UserControl>
